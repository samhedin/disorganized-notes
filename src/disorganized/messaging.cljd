  (println "dismissed " )
  )

^{:annotations [^:unique (pragma "vm:entry-point")]}
(defn  ^#/(Future void) on-action-received [notification]
  (println "action received" (.-buttonKeyPressed notification) (.-actionType notification))
  (let [action (.-buttonKeyPressed notification)
        action-type (.-actionType notification)
        payload (model/dart->clj-ds (.-payload notification))
        m {"note-id" (payload "note_id")
           "section-id" (payload "section_id")
           "description" (payload "description")}]

    (cond
      (= "new_todo_note" (payload "action_type")) (new-todo-note)

      :else (if (not (string/blank? action)) ;;old stuff deal with like this
              (await (exec-reminder-action action m))
              (rd/dispatch [::model/set-current-note-id (payload "note_id")])))))

^{:annotations [^:unique (pragma "vm:entry-point")]}
(defn  ^#/(Future void) fcm-token-handler [token]
  (println "received fcm token" (some? token))
  (let [uid (model/uid)
        device-ref (.doc (FirebaseFirestore.instance.collection "devices")
                         uid)
        tokens {"tokens"
                {token {"createdAt" (DateTime.now)
                        "lastUsed" (DateTime.now)
                        "isActive" true}}}]

    (await (.set device-ref
                 tokens
                 (SetOptions .merge true)))))

^{:annotations [^:unique (pragma "vm:entry-point")]}
(defn  ^#/(Future void) background-handler [^FcmSilentData silentdata]
  (println "notification data " silentdata)
  (await (Future.delayed (Duration .milliseconds 300))))

(defn ^#/(Future bool) initialize-remote-notifications []
  (await (.initialize
          (AwesomeNotificationsFcm)
          .onFcmSilentDataHandle background-handler
          .onFcmTokenHandle fcm-token-handler
          .licenseKeys ["REMOVED"
                        "REMOVED"])))

(defn initialize []
  (.initialize (notif/AwesomeNotifications)
               "resource://drawable/do_logo"
               (into []
                     (concat
                      [(notif/NotificationChannel
                        .channelGroupKey "reminder_channel_group"
                        .channelKey "reminder_channel"
                        .channelName "Reminders"
                        .channelDescription "Reminders from the app!")

                       (notif/NotificationChannel
                        .channelGroupKey "habit_channel_group"
                        .channelKey "habit_channel"
                        .channelName "Habit forming channel"
                        .channelDescription "Get in the note-taking habit!")]

                      (when (= "true" (model/remote-conf "memories"))
                        [(notif/NotificationChannel
                          .channelGroupKey "memory_channel_group"
                          .channelKey "memory_channel"
                          .channelName "Memories"
                          .channelDescription "Remembering notes you wrote in the past")]))))

  (.setListeners (notif/AwesomeNotifications)
                 .onActionReceivedMethod on-action-received
                 ;.onNotificationCreatedMethod on-notification-received
                 .onNotificationDisplayedMethod on-notification-displayed
                 .onDismissActionReceivedMethod on-dismiss-action-received)

  (await (initialize-remote-notifications)))
