(ns disorganized.messaging
  (:require
   ["package:disorganized_notes/firestore_db.dart" :as fdb]
   ["dart:io" :refer [Platform]]
   [hti.re-dash.alpha :as rd]
   ["dart:convert" :as c]
   [clojure.string :as string]
   ["package:flutter/material.dart" :as m]
   ["package:eraser/eraser.dart" :refer [Eraser]]
   ["package:awesome_notifications/awesome_notifications.dart" :as notif :refer [AwesomeNotifications ReceivedAction]]
   ["package:awesome_notifications_fcm/awesome_notifications_fcm.dart" :refer [AwesomeNotificationsFcm FcmSilentData]]
   [disorganized.model :as model]
   ["package:flutter/foundation.dart" :refer [kIsWeb kDebugMode kProfileMode]]
   ["package:cloud_firestore/cloud_firestore.dart" :refer [FirebaseFirestore SetOptions]]
   ["dart:io" :refer [Platform]]))

(defn postpone-notification [duration
                             {:strs [section-id note-id description] :as m}]
  (let [tz (await (.getLocalTimeZoneIdentifier
                   (notif/AwesomeNotifications)))]
    (await
     (.createNotification
      (notif/AwesomeNotifications)

      .content
      (notif/NotificationContent
       .id 0
       .channelKey "reminder_channel"
       .title (model/safe-substring description 0 10)
       .body (model/safe-substring description 0 100)
       .payload m
       .wakeUpScreen true
       .category notif/NotificationCategory.Alarm)

      .actionButtons [(notif/NotificationActionButton
                       .showInCompactView true
                       .actionType notif/ActionType.SilentAction

                       .key "finish"
                       .label "Finish")
                      (notif/NotificationActionButton
                       .showInCompactView true
                       .actionType notif/ActionType.SilentAction

                       .key "postpone-30"
                       .label "Delay 30 min")
                      (notif/NotificationActionButton
                       .showInCompactView true
                       .actionType notif/ActionType.SilentAction

                       .key "postpone-60"
                       .label "Delay 60 min")]

      .schedule
      (notif/NotificationInterval.new
       .timeZone tz
       .interval duration
       .allowWhileIdle true
       .preciseAlarm true)))))

(defn new-todo-note []
  (let [note (model/init-new-note)
        list-section (model/default-section-map "list" 0 "todo")]

    (rd/dispatch [::model/upload-note  [(assoc note
                                               :sections {(list-section "id")
                                                          list-section}
                                               :title "Todo this week"
                                               :tags ["todo"])

                                        true]])
    (model/log-analytics "note_created")
    (rd/dispatch [::model/set-current-note-id (:id note)])))

(defn exec-reminder-action [action {:strs [section-id note-id description] :as m}]
  (case action
    "postpone-30" (await (postpone-notification  (Duration .minutes 30) m))
    "postpone-60" (await (postpone-notification  (Duration .minutes 60) m))

    "finish" (let [db (fdb/FirestoreDB)
                   note' (await (.getNoteById db note-id))
                   note (model/dart->clj-ds note')

                   ;;first first is because (note "sections") is a map
                   ;;which results in [section-name,section] after the filter.
                   section-name (first (first (filter
                                               (fn [[_ section]]
                                                 (= section-id (section "id")))
                                               (note "sections"))))

                   ff  FirebaseFirestore.instance
                   ref (.doc (.collection ff "notes2")
                             note-id)]

               (.set ref
                     (assoc-in note
                               ["sections" section-name "content" "finished"]
                               true)))))

