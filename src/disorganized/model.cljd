  (rd/reg-event-fx ::update-current-note
                   (fn [{:keys [db]} [_ f]]
                     (let [old-note (:current-note db)
                           newnote (f old-note)
                           newnote' (dissoc newnote :just-cloned)]

                       (if (not= newnote (:current-note db))
                         {:db (-> db
                                  (assoc :current-note newnote')
                                  (update
                                   :undo #(conj (take 10 %) ;;Max undo steps
                                                old-note)))
                          ::upload-note-fx {:note newnote'
                                            :update-updated-at? true
                                            :password (:password db)}}

                         {:db db}))))

