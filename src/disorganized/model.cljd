                   (fn [{:keys [db]} _]
                     {:db (assoc db :batch-delete-notes #{})
                      ::run-batch-delete {:ids (:batch-delete-notes db)
                                          :notes
                                          (into {}
                                                (for [note (:notes db)]
                                                  [(:id note) note]))}}))

