  (rd/reg-fx ::upload-note-fx
             (fn [{:keys [note update-updated-at? password]}]
               (cond
                 (:encrypted note) (encrypt-and-upload-note note password)
                 note (let [db FirebaseFirestore.instance
                            fdb (fdb/FirestoreDB)
                             
                            reminders (note-reminders note)
                            ref (.doc (.collection db "notes2")
                                      (:id note))
                            valid-status (valid-note? note)]
                        (.set ref
                                (w/stringify-keys
                                 (if update-updated-at?
                                   (assoc note
                                          :updated_at (FieldValue.serverTimestamp))
                                   note)))
                        
                        (when (not= true valid-status)
                          (dutils/invalidNoteError note (str valid-status)))

                        (when reminders
                          (.uploadReminders fdb (:owner note) reminders)))
                 :else nil)))

