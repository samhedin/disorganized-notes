(defn showtoast [msg]
  (t/Fluttertoast.showToast
   .msg msg
   .toastLength t/Toast.LENGTH_LONG
   .gravity t/ToastGravity.CENTER
   .backgroundColor m/Colors.red
   .textColor m/Colors.white
   .timeInSecForIosWeb 5))

(defn valid-note? [note]
  (let [result (sali/validate schema/note note)]
    (when (not= true result)
      (println (:id note) ": " result))
    (if (= true result)
      true
      (do (showtoast "Note corrupted, reverting change...")
          result))))

(defn validate-all-notes [notes]
  (println (mapv #(sali/validate schema/note %) notes)))

(def gemini-model "gemini-3.1-flash-lite-preview")

(defn days-until
  "How many days until (model/next-weekday DateTime.sunday)?"
  [day]
  (let [today (.-weekday (DateTime.now))]
    (.-inDays (Duration
               .days (mod (- day today)
                          (.-daysPerWeek DateTime))))))

(defn encrypt-string [aes-gcm text secret-key]
  (let [box (await (.encryptString aes-gcm text .secretKey secret-key))
        combined (.concatenation box .nonce true .mac true)]
    (c/base64Encode combined)))

(defn decrypt-string [aes-gcm text secret-key]
  (println "decrypting.. ")
  (let [bytes (c/base64Decode text)
          box (cr/SecretBox.fromConcatenation bytes .nonceLength 12 .macLength 16)]
      (await (.decryptString aes-gcm box .secretKey secret-key))))

(defn encrypt-list-item [item aes-gcm secret-key]

  (let [data (await (encrypt-string aes-gcm (item "data") secret-key))
        children (await
                  (Future.wait
                   (mapv (fn [child]
                           (encrypt-list-item child aes-gcm secret-key))
                         (item "children"))))]
    (assoc item "data" data "children" children)))

(defn decrypt-list-item [item aes-gcm secret-key]

  (let [data (await (decrypt-string aes-gcm (item "data") secret-key))
        children (await
                  (Future.wait
                   (mapv (fn [child]
                           (decrypt-list-item child aes-gcm secret-key))
                         (item "children"))))]
    (assoc item "data" data "children" children)))

(defn encrypt-section [[section-id section] aes-gcm secret-key]
  (await
   (case (section "type")
     "text" (let [text (section "content")
                  name (await (encrypt-string aes-gcm (section "name") secret-key))
                  encrypted-text (await (encrypt-string aes-gcm text secret-key))]
              [section-id (assoc section "content" encrypted-text "name" name)])

     "list" (let [encrypted-items (await (Future.wait
                                          (mapv (fn [item]
                                                  (encrypt-list-item item aes-gcm secret-key))
                                                (section "content"))))
                  name (await (encrypt-string aes-gcm (section "name") secret-key))]
              [section-id (assoc section "content" encrypted-items "name" name)]))))

(defn decrypt-section [[section-id section] aes-gcm secret-key]
  (case (section "type")
    "text" (let [text (section "content")
                 decrypted-text (await (decrypt-string aes-gcm text secret-key))]
             [section-id (assoc section "content" decrypted-text)])

    "list" (let [content (await (Future.wait (mapv (fn [i]
                                                     (decrypt-list-item i aes-gcm secret-key))
                                                   (section "content"))))]

             [section-id (assoc section "content" content)])))

(defn decrypt-note [note password]

  (let [aes-gcm (FlutterAesGcm.with256bits)
        pbkdf2-alg (cr/Pbkdf2
                    .macAlgorithm  (cr/Hmac.sha256)
                    .iterations 100000
                    .bits 256)

        key (await (.deriveKeyFromPassword
                    pbkdf2-alg
                    .password password
                    .nonce (note :salt)))

        plaintext (await (decrypt-string aes-gcm (:plaintext note) key))

        sections (await (Future.wait (mapv (fn [section]
                                             (decrypt-section section aes-gcm key))
                                           (:sections note))))]

    (assoc note
           :plaintext plaintext
           :sections (into {} sections))))

(defn encrypt-and-upload-note [note password]
  (let [note (update note :salt #(or % (randomBytes 16)))
        aes-gcm (FlutterAesGcm.with256bits)

        pbkdf2-alg (cr/Pbkdf2
                    .macAlgorithm  (cr/Hmac.sha256)
                    .iterations 100000
                    .bits 256)

        secret-key (await (.deriveKeyFromPassword
                           pbkdf2-alg
                           .password password
                           .nonce (note :salt)))

        pt (await (encrypt-string aes-gcm (:plaintext note) secret-key))

        allowed-sections #{"table2" "text" "list"}

        fsections (filter (fn [[_ section]]
                            (allowed-sections (section "type"))) (:sections note))

        encrypted-sections (await
                            (Future.wait
                             (mapv (fn [section]

                                     (encrypt-section section aes-gcm secret-key)) fsections)))

        encrypted-note (assoc note
                              :plaintext pt
                              :sections (into {} encrypted-sections))

        ;decrypted-note (await (decrypt-note encrypted-note password))
        ]

    (.set (.doc (.collection FirebaseFirestore.instance "notes2")
                (:id encrypted-note))
          (w/stringify-keys
           (assoc encrypted-note :updated_at (FieldValue.serverTimestamp))))))

(def black-color-seed (m/Color 0x00001d))
(def white-color-seed (m/Color 0xffffff))

(defn unfocus []
  (.unfocus (.-primaryFocus (.instance m/FocusManager))))

(defn exit-edit-note
  "Don't call this during clone operations since it unsets current-note-local on a delay."
  [scaffold-messenger old-note?]
  (unfocus-then-run
   (rd/dispatch [::set-key :ai-generating-section false])
   (rd/dispatch [::reset-restructure-mode])
   (rd/dispatch [::reset-undo-stack])
   (rd/dispatch [::delete-if-not-edited])
   (rd/dispatch [::replace-current-note-in-notes])

   (when old-note?
     (rd/dispatch [::set-current-note-local old-note?]))))

(defn import-note "Should only be used for importing notes, see the :imported key"
  [note]
  (let [fdb (fdb/FirestoreDB)
        {user-id :user-id
         email :email} (current-user)]
    (await (.insertNote fdb
                        (w/stringify-keys
                         (-> note
                             (update
                              :roles
                              #(or % {user-id "owner"}))
                             (assoc :imported true)
                             (update :tags #(into [] (conj % "imported")))))
                        user-id
                        (:id note)
                        email
                        .updateUpdatedAt false))))

(defn function-call [name params]
  (await
   (.call
    (FirebaseFunctions.instance.httpsCallable name)

    (dutils/stringKeys
     params))))

(defn dart->clj-ds [m]
  (cond
    (instance? Map m) (into {} (map (fn [[k v]]
                                      [(dart->clj-ds k)
                                       (dart->clj-ds v)])) m)
    (instance? List m) (into [] (map dart->clj-ds) m)
    :else m))

(defn uid []
  (let [user (-> FirebaseAuth .-instance .-currentUser)]
    (when user (.-uid user))))

(defn init-new-note []
  (let [uid (uid)]
    {:roles
     {uid "owner"}
     :id (str (random-uuid))
     :title ""
     :tags []
     :sections {}
     :owner uid
     :user_access [uid]
     :created_at (.now DateTime)
     :updated_at (.now DateTime)
     :plaintext ""}))

(defn note-contains-section? [note section-type]
  (some (fn [[_ section]]
          (if (= "table2" section-type)
            (or (= "table" (section "type"))
                (= "table2" (section "type")))

            (= section-type
               (section "type"))))
        (:sections note)))

(defn firestore-stream->map [stream]
  (when (and stream (.-exists stream))
    (dart->clj-ds
     (.data stream))))

(defn snackbar
  "Action example (m/SnackBarAction .label string .OnPressed (fn [] )"
  [scaffold-messenger text & [action?]]
  (if action?
    (.showSnackBar scaffold-messenger
                   (m/SnackBar
                    .content (m/Text text)
                    .persist false)
                   .action action?)

    (.showSnackBar scaffold-messenger
                   (m/SnackBar .content (m/Text text)))))

(defn url-button [{:keys [url text-preview]}]
  (f/widget
   :watch [brightness (rd/subscribe [::get-brightness])]
   :let [^m/TextStyle faded (theme/faded-text-style brightness)]
   :get {{tthm .-textTheme} m/Theme}

   (m/TextButton
    .child
    (m/Text
     (if (string/blank? text-preview)
       (string/replace
        (if (> (count url) 40)
          (str (subs url 0 39) "...")
          url)
        #"https://|www." "")
       text-preview)
     .overflow m/TextOverflow.ellipsis
     .style (.merge faded (.-bodySmall tthm)))

    .onPressed (fn []
                 (url/launch (if (string/includes? url "http")
                               url
                               (str "https://" url)))
                 nil))))

(defn schedule-alarm [{:keys [content description section-name note-id alarm-id section section-id]}]
  (let [duration (Duration
                  .seconds (or (content "seconds") 0)
                  .minutes (or (content "minutes") 0)
                  .hours (or (content "hours") 0))
        dt (.add (DateTime.now) duration)
        settings (alarm/AlarmSettings
                  .payload (prn-str
                            {:section-name section-name
                             :note-id note-id
                             :section-id section-id
                             :section-position (section "section-position")
                             :seconds (or (content "seconds") 0)
                             :minutes (or (content "minutes") 0)
                             :hours (or (content "hours") 0)})

                  .androidFullScreenIntent false
                  .id alarm-id
                  .loopAudio true
                  .vibrate true
                  .dateTime dt

                  .assetAudioPath "assets/alarm.mp3"

                  .volumeSettings ^:unique (alarm/VolumeSettings.fade
                                            .fadeDuration (Duration .seconds 10))

                  .notificationSettings (alarm/NotificationSettings
                                         .icon "assets/do_logo"
                                         .title section-name
                                         .body (or description section-name "Alert!")
                                         .stopButton "Stop"))]
    (await (alarm/Alarm.set
            .alarmSettings settings))
    nil))

(defn safe-substring [s start end]
  (subs (str s) start (min (count s) end)))

(def fullscreen-animation-duration (Duration .milliseconds 600))
(def wide-screen-threshold 800)

(def decimal-number-format (NumberFormat "#.##"))

(defn format-number [v]
  (str (.format decimal-number-format v)))

