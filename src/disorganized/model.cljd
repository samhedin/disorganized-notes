(defmacro unfocus-then-run [& body]
  `(do
     (.unfocus (.-primaryFocus (.instance m/FocusManager)))
     (.addPostFrameCallback
      (.-instance m/WidgetsBinding)
      (fn [_#]
        ~@body))))

(defn smart-sort-list [items]

  (when (seq items)
    (try
      (let [raw (mapv #(% "data") items)
            output (await (.call (FirebaseFunctions.instance.httpsCallable "sort_list_req")
                                 (dutils/stringKeys {"items" raw})))
            sorted-names (get (.-data output) "sorted")
            ;; Create a map of data name to its index in sorted list
            position-map (zipmap sorted-names (range))
            ;; Sort items based on index of their data name in sorted-names
            sorted-items (sort-by #(get position-map (% "data")) items)]

        (into [] sorted-items))
      (catch Exception e nil))))

