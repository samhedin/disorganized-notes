  (defn intersecting-tags
    "Returns a map from tag -> tags that occur in any note alongside it.
  The mapping always includes itself, because we always want to show any currently selected tags."
    [notes]
    (reduce
     (fn [tag->related-tags {:keys [archived tags]}]
       (if archived
         tag->related-tags
         (let [tag-set (set tags)]
           (reduce
            (fn [tag->related-tags tag]
              (update tag->related-tags tag
                      #(into (or % #{}) tag-set)))
            tag->related-tags
            tags))))
     {}
     notes))

  (rd/reg-flow
   {:id :all-tags
    :inputs {:notes [:notes]
             :pinned-tags [:pinned-tags]}
    :path [:all-tags]
    :output
    (fn [{:keys [notes pinned-tags]}]
      {:all-tags

       (distinct (concat pinned-tags
                         (filter some?
                                 (flatten
                                  (keep (fn [{:keys [archived tags]}]
                                          (when (not archived)
                                            tags)) notes)))))
       :intersecting-tags (intersecting-tags notes)})})

