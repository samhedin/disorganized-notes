  (rd/reg-fx ::insert-note
             (fn [[note update-created-at? just-deleted-id]]
               (when  (not= just-deleted-id (:id note))
                 (let [{user-id :user-id
                        email :email} (current-user)
                       fdb (fdb/FirestoreDB)
                       cr? (if (nil? update-created-at?) true update-created-at?) ;;Get rid of nil
                       reminders (note-reminders note)]

                   (await (.insertNote fdb
                                       (w/stringify-keys
                                        (update note
                                                :roles
                                                #(or % {user-id "owner"})))
                                       user-id
                                       (:id note)
                                       email
                                       .updateUpdatedAt cr?))

                   (when reminders
                     (.uploadReminders fdb user-id reminders))
                   (rd/dispatch [::refresh-notes])))))

