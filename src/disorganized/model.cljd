  (rd/reg-event-db
   ::replace-current-note-in-notes
   (fn [db _]
     (let [index (:id->saved-notes-index db)
           note (-> (:current-note db)
                    (update :created_at #(if % (.toDate %)
                                             (.subtract (DateTime.now) (Duration .minutes 1))))
                    (update :updated_at #(if % (.toDate %)
                                             (DateTime.now))))
           pinned-at (when-let [p (:pin note)]
                       (.toDate p))

           ;;If the note is pinned it should have a stable location
           ;;if not it should just go to the top.
           insertion-index (if (:pin note)
                             (count (take-while (fn [{:keys [pin]}]

                                                  (when pin
                                                    (.isBefore (.toDate pin)
                                                               pinned-at))) (:notes db)))
                             0)
           i (index (:id note))]

       (if i
         (update db :notes
                 (fn [notes]
                   (-> notes
                       (vec-remove i)
                       (vec-add insertion-index note))))
         (update db :notes
                 (fn [notes]
                   (vec-add notes insertion-index note)))))))

