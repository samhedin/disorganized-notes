                                 (let [id->index (:id->saved-notes-index db)
                                       saved-notes (:notes db)
                                       index (when id->index
                                               (id->index (:id note)))
                                       saved-note (when index
                                                    (nth saved-notes index))]

                                   (if  (and (or (seq (:sections note))
                                                 (not (string/blank? (:plaintext note)))
                                                 (not (string/blank? (:title note))))
                                             (not= saved-note note))
                                     {:db db
                                      ::insert-note [note
                                                     update-created-at?
                                                     (:just-deleted db)]}
                                     {:db db}))))
