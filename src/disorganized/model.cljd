  (rd/reg-fx ::run-batch-delete
             (fn [{:keys [ids notes]}]
               (let [db (fdb/FirestoreDB)]

                 (doseq [id ids
                         :let [note (notes id)]]
                   (await (.deleteNote db
                                       id
                                       (:user-id (current-user)))))

                 (doseq [id ids
                         :let [note (notes id)]
                         [section-id section] (:sections note)
                         :when (or (= "alarm" (section "type"))
                                   (= "timer" (section "type")))]
                   (await (Alarm.stop (.-hashCode section-id)))))

               (rd/dispatch [::refresh-notes])))

