(defn all-sections-empty? [sections]
  (reduce-kv (fn [_ _ section]
               (let [content (section "content")
                     empty-content? (case (section "type")
                                      "table" (empty? content)
                                      "media" (empty content)
                                      "list" (and (empty content)
                                                  (empty (section "checked-content")))
                                      "reminder" false
                                      "text" (string/blank? content))]

                 (if (not empty-content?)
                   (reduced false)
                   true)))
             false
             sections))

(def elevated-button-style
  (m/ElevatedButton.styleFrom
   .shape (m/RoundedRectangleBorder
           .borderRadius (m/BorderRadius.circular 5.0))
   .elevation 0.4))

(defn outlined-button-style [tthm]
  (let [color (.-color (.-titleLarge tthm))]
    (m/OutlinedButton.styleFrom
     .shape (m/RoundedRectangleBorder
             .borderRadius (m/BorderRadius.circular 15))
     .side (m/BorderSide .width 0.4 .color color))))

(defn button-style [tthm button]
  (let [color (.-color (.-titleLarge tthm))
        style (outlined-button-style tthm)]
    (case button
      "elevated" (m/ElevatedButtonThemeData
                  .style
                  (m/ElevatedButton.styleFrom
                   .elevation 1
                   .shape (m/RoundedRectangleBorder
                           .borderRadius (m/BorderRadius.circular 15))

                   .side (m/BorderSide
                          .style (m/BorderStyle.none))))

      "outlined" (m/OutlinedButtonThemeData .style style))))

(defn url->preview [url]
  (await (AnyLinkPreview.getMetadata
          .link url
          .cache (Duration .days 7)
          .proxyUrl "https://cors-989769042149.europe-west1.run.app/cors?"
          .userAgent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36")))

(defn find-urls [text]
  (let [url-pattern #"https?:\/\/[a-zA-Z0-9\-_]+(\.[a-zA-Z0-9\-_]+)+(:\d+)?(\/[^\s]*)?"
        urls (->> (re-seq url-pattern (or text ""))
                  (map first)
                  vec)
        previews (await (Future.wait
                         (map (fn [u]
                                (url->preview u)) urls)))]

    (map (fn [u p]
           {:url u
            :text-preview (str (when p (.-title p)))}) urls previews)))

(defn print [s]
  (when (or kDebugMode kProfileMode)
    (println s)))

(defn links [^m/TextTheme tthm]
  (f/widget
   :watch [{:keys [plaintext]} (rd/subscribe [::current-note])
           brightness (rd/subscribe [::get-brightness])]
   :padding {:horizontal 10}
   :watch [urls (find-urls plaintext)]
   :let [^m/TextStyle faded (.merge
                             (.-bodySmall tthm)
                             (theme/faded-text-style brightness))]
   (m/Align
    .alignment m/Alignment.bottomLeft)
   (m/Wrap
    .children (map url-button urls))))

(defn url-buttons [text]
  (f/widget
   :watch [{:keys [plaintext]} (rd/subscribe [::current-note])
           brightness (rd/subscribe [::get-brightness])]
   :padding {:horizontal 10}
   :watch [urls (find-urls text)]
   :get {{tthm .-textTheme} m/Theme}
   :let [^m/TextStyle faded (.merge
                             (.-bodySmall tthm)
                             (theme/faded-text-style brightness))]
   (m/Align
    .alignment m/Alignment.bottomLeft)
   (m/Wrap
    .children (map url-button urls))))

(defn reset-content [content v]
  (cond
    (string? content) ""
    (= "reminder" (v "type"))
    {"datetime"
     (Timestamp.fromDate
      (.toUtc (.now DateTime)))
     "description" ""
     "id" (str (random-uuid))
     "finished" false}

    (= "timer" (v "type"))
    content

    (= "table" (v "type"))
    [{"id" (str (random-uuid))
      "data" (into {}
                   (map
                    (fn [k]
                      [k ""])
                    (keys ((first content) "data"))))}]

    (= "table2" (v "type"))
    [{"id" (str (random-uuid))
      "data" (into {}
                   (map
                    (fn [k]
                      [k ""])
                    (keys ((first content) "data"))))}]

    (= "list" (v "type")) [{"id" (str (random-uuid))
                            "children" []
                            "data" ""}]
    :else (empty content)))

(defn clone-note
  "Clones a note. It is important that the new note is initated via init-new-note,
  because simply copying the old note and emptying the sections could lead to copying unwanted fields. For example, for default notes which have a :default key, any clones of those should not be treated as default notes."
  [note ^m/ScaffoldMessengerState scaffold-messenger premium?]
  (log-analytics "note_cloned")
  
  (let [default-note (init-new-note)]
    (-> default-note
        (assoc :tags (:tags note)
               :just-cloned true)
        (assoc
         :sections
         (into {} (map (fn [[k v]]
                         (let [id (str (random-uuid))
                               v (-> v
                                     (update "content" #(reset-content % v))
                                     (assoc "id" id))]
                           [id (cond
                                 (= "list" (v "type")) (update v "checked-content" #(empty %))
                                 (= "voice" (v "type")) (assoc v "start-recording?" false)
                                 :else v)])))
               (:sections note))))))

(defn reset-checkboxes [note]
  (into {} (for [[section-id section] (:sections note)]
             (cond
               (= "list" (section "type"))
               [section-id (update section "content"
                                   (fn [c]
                                     (mapv
                                      #(assoc % "checkbox" false) c)))]

               (= "table2" (section "type"))
               [section-id (update section "content"
                                   (fn [rows]
                                     (mapv #(assoc % "checkbox" false) rows)))]

               (= "voice" (section "type")) [section-id (assoc section "content"
                                                               {})]
               (= "media" (section "type")) [section-id (update section "content" empty)]
               :else [section-id section]))))

(defn get-new-plaintext [plaintext]
  ;;If there was no plaintext then let it be, we'll compute title in other ways.
  (if (< 0 (count plaintext))
    (if-let [match (or (re-find #"-(\d+)$" plaintext)
                       (re-find #" (\d+)$" plaintext))]
      (let [num (int/parse (second match))
            base (subs plaintext 0 (- (count plaintext) (count (first match))))]
        (str (string/trim base) " " (inc num)))
      (str (string/trim plaintext) " 1"))
    ""))

(defn log-crashlytics [log]
  (when (and
         (not kIsWeb)
         (not kDebugMode))
    (FirebaseCrashlytics.instance.log log)))

(defn outline
  ([child] (outline child 0.5 1 20))

  ([child glow-opacity border-thickness border-radius]
   (ZoAnimatedGradientBorder
    .glowOpacity glow-opacity
    .borderRadius border-radius
    .animationCurve m/Curves.linear
    .borderThickness border-thickness
    .gradientColor [m/Colors.yellow m/Colors.orange]

    .animationDuration (Duration .seconds 4)
    .child child)))

(defn log-analytics
  "DON'T PUT SPACES IN HERE"
  ([name] (log-analytics name {}))
  ([name parameters]
   (assert (not (string/includes? name "-")))
   (doseq [[k v] parameters]
     (println "LOG ANALYTICS " k v)
     (assert (not (string/includes? k "-")))
     (assert (not (string/includes? (str v)  "-"))))

   (when (not kDebugMode)
     (let [analytics (await (.instance fa/FirebaseAnalytics))]
       (.logEvent analytics
                  .name name
                  .parameters
                  (dutils/convertToStr (Map.from parameters)))))))

(defn init-new-recording-note []
  (let [uid (uid)]
    {:roles
     {uid "owner"}
     :id (str (random-uuid))
     :start-recording? true
     :sections  (let [m (default-section-map "voice" 0 "voice")]
                  {(m "id") (assoc m "start-recording?" true)})
     :title ""
     :owner uid
     :tags []
     :user_access [uid]
     :created_at (.now DateTime)
     :updated_at (.now DateTime)
     :plaintext ""}))

(defn headline
  ([^m/TextTheme tthm level] (headline tthm level nil))
  ([^m/TextTheme tthm level decoration]
   (let [size (case level
                8 (.-headlineLarge tthm)
                7 (.-headlineMedium tthm)
                6 (.-titleLarge tthm)
                5 (.-titleMedium tthm)
                4 (.-labelLarge tthm)
                3 (.-labelMedium tthm)
                2 (.-bodyLarge tthm)
                1 (.-bodyMedium tthm))]
     (if decoration
       (.copyWith
        size)
       size))))

(defn set-crash-key [k v]
  (when (not kIsWeb)
    (FirebaseCrashlytics.instance.setCustomKey
     (str k) (str v))))

(defn restore-purchase []
  (let [info (await (rc/Purchases.restorePurchases))
        entitlements (into {} (.-all (-> info .-entitlements)))
        active? (when (seq entitlements)
                  (.-isActive (entitlements "full-access")))]
    (rd/dispatch [::set-key :premium? active?])))

(defn set-premium []
  (let [status (if
                kIsWeb (await (dutils/getSubscriptionStatusWeb (uid)))

                (let [^rc/CustomerInfo info (await (rc/Purchases.getCustomerInfo))
                      entitlements (into {} (.-all (-> info .-entitlements)))]
                  (when (seq entitlements)
                    (.-isActive (entitlements "full-access")))))]
    (println "setting premium: " status)
    (rd/dispatch [::set-key :premium? status])))

(defn init-revenuecat- [user-id]
  (when (and (some? user-id)
             (not kIsWeb))
    (let [config
          (cond
            Platform.isAndroid
            (rc/PurchasesConfiguration secrets/revenueCatAndroid)
            Platform.isIOS
            (rc/PurchasesConfiguration secrets/revenueCatIos))]

      (.-appUserID! config user-id)
      (await (rc/Purchases.configure config))))
  ;;Always set premium, even for web
  (await (set-premium)))

(defn paywall [^m/ScaffoldMessengerState scaffold-messenger]
  (println "paywall")
  (if kIsWeb (snackbar scaffold-messenger "This feature requires a premium account. Please subscribe to premium using the Android or iOS app and then try again.")
      (when
       (= rcu/PaywallResult.purchased
          (await (rcu/RevenueCatUI.presentPaywallIfNeeded
                  "full-access"
                  .displayCloseButton true)))
        (rd/dispatch [::set-key :premium? true])
        (snackbar scaffold-messenger "Premium granted! It should be ready immediately. If not, please restart the app."))))

(defn prompt-to-paywall [^m/ScaffoldMessengerState scaffold-messenger prompt]
  (.showSnackBar
   scaffold-messenger
   (m/SnackBar
    .content (m/Text prompt)
    .action (m/SnackBarAction
             .label "Subscribe"
             .onPressed
             (fn []
               (paywall scaffold-messenger)
               nil)))))

(defn show-login [ctx ^m/ScaffoldMessengerState scaffold-messenger]
  (-> ctx go_router/GoRouterHelper
      (.pushNamed
       "login"))
  (.showSnackBar
   scaffold-messenger
   (m/SnackBar
    .content (m/Text "Please register for cloud backups and multi-device sync."))))

(defn delete-note [id]
  (let [uid (:user-id (current-user))
        db (fdb/FirestoreDB)]
    (try (await (.deleteNote db
                             id
                             uid))
         (catch dynamic e))))

(defn should-show-ads? [can-request-ads?]
  (Future/delayed
   (Duration .milliseconds 5)
   (fn []
     false)))

(defn map-deep-into [m]
  (into {}
        (for [[k v] m]
          [k (cond
               (instance? #/(Map String dynamic) v) (map-deep-into v)
               :else v)])))

(defn vec-remove
  "Remove elem in coll by index."
  [coll pos]
  (vec (concat (subvec coll 0 pos) (subvec coll (inc pos)))))

(defn vec-add
  "Add elem in coll by index."
  [coll pos el]
  (vec (concat (subvec coll 0 pos) [el] (subvec coll pos))))

(defn vec-move
  "Move elem in coll by index, handling out of bounds indices"
  [coll pos1 pos2]
  (if (empty? coll)
    coll
    (let [el (nth coll pos1)]
      (if (= pos1 pos2)
        coll
        (vec-add (vec-remove coll pos1) pos2 el)))))

(defn uniq-by
  ""
  [f items]
  (:uniq (reduce (fn [acc m]
                   (let [k (f m)]
                     (if (get-in acc [:seen k])
                       acc
                       (-> acc
                           (update :seen assoc k true)
                           (update :uniq conj m)))))
                 {:seen {} :uniq []}
                 items)))

(comment
  (uniq-by :name [{:name "Bob"} {:name "Jane"} {:name "Bob"}]))

(defn list-completion [notes]
    ;;All list items
  (take 500
        (uniq-by :data
                 (flatten
                  (map (fn [{:keys [sections]}]
                         (keep (fn [[_ {:strs [type content checked-content]}]]
                                 (when (= "list" type)
                                   (flatten
                                    (for [c [content checked-content]]
                                      (for [item c
                                            :when item]
                                        {:id (item "id")
                                         :data (string/trim (str (item "data")))})))))
                               sections))
                       (take 100 notes))))))

(defn table-completion [notes]
  (group-by
   :c
   (take 500
         (distinct
          (flatten
           (for [n (take 100 notes)]
             (for [[_ section] (take 10 (:sections n))
                   :when (= "table2" (section "type"))
                   row (take 20 (section "content"))
                   :when (seq (section "content"))
                   [c v] (take 30 (row "data"))
                   :when (seq (row "data"))]
               {:string v
                :c c
                :row (row "data")})))))))

(defn collision-counter [s]
  (if (re-find #"\((\d+)\)$" s)
    (clojure.string/replace s #"\((\d+)\)$"
                            #(str "(" (inc (int.parse (second %))) ")"))
    (str s " (1)")))

(defn current-user []
  (let [user (-> FirebaseAuth .-instance .-currentUser)]
    (when user {:user-id (.-uid user)
                :email (.-email user)})))

(defn map-deep-into [m]
  (into {}
        (for [[k v] m]
          [k (cond
               (instance? #/(Map String dynamic) v) (map-deep-into v)
               :else v)])))

(defn sort-by-order [items order-list]
  (let [type-index (zipmap order-list (range))]
    (sort-by #(get type-index (get (second %) "type")) items)))

(defn merge-text [t1 t2]
  (if (string/includes? (or t1 "")
                        (or t2 ""))
    t1
    (string/join "\n" [t1 t2])))

(defn add-rowcalcs-to-columns? [columns rowcalcs]
  (for [rc rowcalcs]
    (let [cols (into #{} (rc "columns"))
          constant (rc "constant")
          sign (case (rc "operation")
                 "sum" "+"
                 "multiply" "*")
          calc-header (keep (fn [c]
                              (when (cols (c "cid"))
                                (c "name"))) columns)]
      (str "("
           sign
           " "
           (string/join " " calc-header)
           (when constant (str " " constant))
           ")"))))

(defn table2-calculate-rows [rowcalcs columns rows]
  (println "columns" columns)
  (println "rows" rows)
  (map
   (fn [row]
     (let [data (row "data")]
       (map
        (fn [rc]
          (let [op (case (rc "operation")
                     "sum" +
                     "multiply" *)
                zero (case (rc "operation")
                       "sum" 0
                       "multiply" 1)
                cols (into #{} (rc "columns"))
                constant (rc "constant")
                [s processed?]
                (reduce-kv
                 (fn [[acc processed?] k v]
                   (if (cols k)
                     (try
                       [(op acc (double.parse (str v))) true]
                       (catch FormatException e
                         [acc processed?]))
                     [acc processed?]))
                 [zero false]
                 data)
                s (if processed? s 0)
                result (if constant
                         (op constant s)
                         s)]
            (str result)))
        rowcalcs)))
   rows))

(defn table2-calculate-columns [calculations columns rows]
  (let [cids (set (keys calculations))]
    (map
     (fn [col]
       (let [cid (col "cid")]
         (if (contains? cids cid)
           (let [op (case (calculations cid)
                      "sum" +
                      "multiply" *)
                 zero (case (calculations cid)
                        "sum" 0
                        "multiply" 1)
                 result (reduce
                         (fn [acc row]
                           (let [val (get-in row ["data" cid])]
                             (try
                               (op acc (double.parse (str val)))
                               (catch FormatException e
                                 acc))))
                         zero
                         rows)]
             (str (case (calculations cid)
                    "sum" "+"
                    "multiply" "*")
                  result))
           ""))) ; if no calculation, leave blank
     columns)))

(defn get-download-links [folder-id]
  (let [storage-ref (FirebaseStorage.instance.ref)
        path (str "/media/"
                  (:user-id (current-user))
                  "/"
                  folder-id)
        images-ref (await
                    (.listAll
                     (.child storage-ref path)))
        urls (await (Future.wait (mapv #(.getDownloadURL %) (.-items images-ref))))]
    (mapv (fn [url item]
            {:url url
             :ref item}) urls (.-items images-ref))))

(defn update-item-and-children
  "Recursively update checkbox state for an item and all its children"
  [item checked?]
  (if checked?
    (-> item
        (assoc "checkbox" true)
        (update "children" #(mapv (fn [child] (update-item-and-children child true)) %)))
    item))

(defn merge-vectors
  "Add all missing elements in v2 to v1"
  [v1 v2]
  (vec (concat v1 (remove (set v1) v2))))

(defn first-section-with-content [sections]
  ;;First try to get a section with proper content
  (if-let [s (some (fn [s]
                     (let [section (second s)]

                       (case (section "type")
                         "text" (when (not (string/blank? (section "content")))
                                  s)

                         "list" (when (seq (section "content"))
                                  s)

                         "table2" (when (seq (section "content"))
                                    s)

                         "table" (when (seq (section "content"))
                                   s)

                         "reminder" (let [desc (get-in section ["content" "description"])]
                                      (when (not (string/blank? desc))
                                        s))
                         "voice" (when-let [t (get-in section ["content" "transcription2"])]
                                   t)
                         nil)))  (sort-by (fn [[_ {:strs [section-position]}]]
                                            section-position)
                                          sections))]
    s
    ;;But if that doesn't exist we'll have to try just the section names.
    (first (sort-by-order sections ["reminder" "table" "list" "text" "media"]))))

(defn reminder-string [content timeformat-24-hours?]
  (if (content "datetime")
    (let [^Timestamp ts (content "datetime")
          dt (df/DateFormatter.getVerboseDateTimeRepresentation (.toLocal (.toDate ts)) timeformat-24-hours?)]
      (if (string/blank? (content "description"))
        (str dt)
        (str dt ": " (content "description"))))
    "Reminder without date set"))

(defn list-string [content section-name]
  (if (seq content)
    (clojure.string/join ", " (map (fn [{:strs [data children]}]
                                     (if (seq children)
                                       (str data ", "
                                            (clojure.string/join ", "
                                                                 (map (fn [{:strs [data]}] data)
                                                                      children)))
                                       data)) (take 3 content)))
    section-name))

(defn table-string [rows columns section-name]
  (if
      ;;This checks if there is content to use as title
   (and (seq rows) ;;there is a row
           ;;... and the content in the first column isn't blank
        (not (string/blank?
              (-> rows
                  first
                  (#(% "data"))
                  (#(% (first columns)))))))
    (string/join ", "
                 (map (fn [{:strs [data]}]
                        (data (first columns)))
                      (take 3 rows)))
    (if (= "table" section-name)
      (string/join " | " (take 3 columns))
      section-name)))

(defn table2-string [rows columns section-name]
  (if
      ;;This checks if there is content to use as title
   (and (seq rows) ;;there is a row
        (not (string/blank?
              (-> rows
                  first
                  (#(% "data"))
                  (#(% ((first columns) "cid")))))))
    (str (string/join ", "
                      (map (fn [{:strs [data]}]
                             (data ((first columns) "cid")))
                           (take 3 rows))))
    (if (= "table" section-name)
      (string/join " | " (take 3 (map #(% "name") columns)))
      section-name)))

(defn gps-string [content]
  (println "gps content " content)
  (if-let [p (content "placemark")]
    (let [pp (dart->clj-ds
              (c/jsonDecode p))]
      (string/join ", "
                   (filter #(not (string/blank? %))
                           [(pp "street")  (pp "postalCode") (pp "locality") (pp "country")])))
    "location"))

(defn make-plaintext [[section-id {:strs [type content columns name] :as m}] timeformat-24-hours?]
  (let [section-name name]
    (case type
      nil ""
      "table" (table-string content columns section-name)
      "table2" (table2-string content columns section-name)

      "list" (list-string content section-name)
      "text" (if (string/blank? content) section-name content)
      "media" (let [captions (or (content "captions" {}))]
                (or
                 (first
                  (vals captions))
                 "media"))
      "media2" (let [captions (or (content "captions" {}))]
                 (or
                  (first
                   (vals captions))
                  (if (= "media2" section-name)
                    "media"
                    section-name)))
      "location" (gps-string content)
      "reminder" (reminder-string content timeformat-24-hours?)
      "voice" (if-let [t (content "transcription")]
                t
                "voice-recording")
      (str section-name))))

(defn default-title [title plaintext  created_at sections timeformat-24-hours?]
  (let [first-line (string/trim (first (string/split plaintext #"[`\n]")))
        section (make-plaintext (first-section-with-content sections) timeformat-24-hours?)]

    (cond
      (and (not (string/blank? title))
           (not (string/blank? first-line))
           (not (string/blank? section))) (str title "\n" first-line "\n" section)
      (string/blank? first-line) section
      (string/blank? section) first-line
      :else (str first-line ": " section))))

(defn default-title-note-input [note]
  (default-title (:title note) (:plaintext note) (:created_at note) (:sections note) false))

(defn default-section-map [section-type number-of-existing-sections name]
  (println "default section map")
  (merge {"type" section-type
          "name" (string/capitalize (str name))
          "section-position" number-of-existing-sections
          "id" (str (random-uuid))}

         (case section-type
           "location" {"content" {}}
           "alarm" {"content" {}}
           "mindmap" {"content" {"parent" nil
                                 "children" nil}}
           "timer" {"content" {"seconds" 0
                               "minutes" 0
                               "hours" 0}
                    "description" ""}

           ;;This is the old table which shouldn't be used anymore
           ;;Shown here if structure needs to be reffered to
           ;; "table" {"columns" ["A" "B"]
           ;;          "content" [{"id" (str (random-uuid))
           ;;                      "data" {"A" ""
           ;;                              "B" ""}}
           ;;                     {"id" (str (random-uuid))
           ;;                      "data" {"A" ""
           ;;                              "B" ""}}]}

           "table2" (let [aid (str (random-uuid))
                          bid (str (random-uuid))]

                      {"columns" [{"name" "A"
                                   "cid" aid}
                                  {"name" "B"
                                   "cid" bid}]

                       "content" [{"id" (str (random-uuid))
                                   "data" {aid ""
                                           bid ""}}
                                  {"id" (str (random-uuid))
                                   "data" {aid ""
                                           bid ""}}]})

           "draw2" {"content" {"captions" {}}}

           "media2" {"content" {"captions" {}}}
           "voice" {"content" {}}

           "list"
           {"content" [{"id" (str (random-uuid))
                        "children" []
                        "data" ""}]
            "checked-content" [] ;;same datastructure as "content". checking/unchecking sends items between these two keys
            "checkboxes-visible" true}
           "reminder"
           {"content" {"datetime"
                       (let [current-date (.now DateTime)]
                         (Timestamp.fromDate
                          (.toUtc (.add (DateTime
                                         (.-year current-date)
                                         (.-month current-date)
                                         (.-day current-date)
                                         (.-hour current-date)
                                         0)
                                        (Duration .days 1)))))
                       "description" ""
                       "id" (str (random-uuid))
                       "finished" false}}
           "text" {"content" ""})))

(defn user-is-anonymous []
  (let [user? (.-currentUser (FirebaseAuth.instance))]

    (when user?
      (.-isAnonymous user?))))

(defn select-all-notes []

  (let [uid (uid)
        db (fdb/FirestoreDB)
        notes (when uid (await (.getAllNotes db uid)))]

    (into []
          (for [note notes
                :let [n (into {} (for [[k v] note]
                                   [(keyword k) (dart->clj-ds v)]))]
                :when (or (not (string/blank? (:plaintext n)))
                          (not (string/blank? (:title n)))
                          (seq (:sections n))
                          (seq (:tags n)))]
            n))))

(defn move-notes-to-section-id-key [notes]
    ;;Already migrated (uuids are 36 long, old section-names max 30)
  (let [already-migrated? (some (fn [note]
                                  (= 36 (count (-> note :sections first first))))
                                notes)
        new-notes
        (if  already-migrated?
          notes
          (into []
                (for [n notes]
                  (update
                   n
                   :sections
                   (fn [sections]
                     (into {}
                           (for [[section-name section] sections]
                             (cond
                               ;;Double check if first note didn't have sections
                               (= 36 (count section-name))
                               [section-name section]

                               (section "id")
                               [(section "id")
                                (assoc section "name" section-name)]

                               :else (let [id (str (random-uuid))]
                                       [id
                                        (assoc section
                                               "name" section-name
                                               "id" id)])))))))))]

    (when (not already-migrated?)
      (rd/dispatch [::save-notes-event-fx new-notes]))

    new-notes))

(defn sort-reminders
  "Put any finished reminders at the bottom, otherwise sort by date"
  [reminders]
  (sort-by (fn [reminder]
             [(if (reminder "finished") 1 0)
              (reminder "date")])
           reminders))

(defn note-reminders
  "If a note has a reminder, returns the content as a map. Since a note can contain many reminders it needs to be flattened."
  [note]
  (keep (fn [[section-name {:strs [type content id]  :as m}]]
          (when (= type "reminder")
            (-> content (assoc
                         "note-id" (:id note)
                         "section-id" id
                         "section-name" section-name)
                (update "description"
                        (fn [d]
                          (cond
                            (not (string/blank? d)) d
                            (not (string/blank? (:title note))) (:title note)
                            :else (:plaintext note)))))))
        (:sections note)))

(defn upload-token [token uid]
  (println "upload token " uid)
  (let [device-ref (.doc (FirebaseFirestore.instance.collection "devices")
                         uid)
        tokens {"tokens"
                {token {"createdAt" (DateTime.now)
                        "lastUsed" (DateTime.now)
                        "isActive" true}}}]

    (await (.set device-ref
                 tokens
                 (SetOptions .merge true)))))

(defn remote-conf
  ([key] (remote-conf key :string))
  ([key type]
   (let [rc frc/FirebaseRemoteConfig.instance
         v (case type
             :bool (.getBool rc key)
             :string (.getString rc key)
             :double (.getDouble rc key)
             :int (.getInt rc key))]
     v)))

(defn request-notification-permission [& [always-request?]]

  (let [is-allowed? (await (.isNotificationAllowed (notif/AwesomeNotifications)))]
    (when (not is-allowed?)
      (let [prefs (await (sp/SharedPreferences.getInstance))
            requested? (await (.getBool prefs "requested_notification_permission"))]

        (when (or (not requested?) always-request?)
          (await (.setBool prefs "requested_notification_permission" true))
          (await (.requestPermissionToSendNotifications
                  (notif/AwesomeNotifications))))))

    (when-let [token (await (.requestFirebaseAppToken (AwesomeNotificationsFcm)))]

      (await (upload-token token (uid)))))

  nil
  ;; (let [fi FirebaseMessaging.instance
  ;;       settings (await (FirebaseMessaging.instance.requestPermission
  ;;                        .alert true
  ;;                        .badge true
  ;;                        .criticalAlert true
  ;;                        .sound true))
  ;;       apnsToken (when (and (not kIsWeb) Platform.isIOS)
  ;;                   (await (FirebaseMessaging.instance.getAPNSToken)))
  ;;       token
  ;;       (cond
  ;;         kIsWeb (FirebaseMessaging.instance.getToken .vapidKey "BOfkI4twQh3a7KPJ5u4daBnWWESqg9zgv-c1wqjUsQ-lqxyWQ-tc_E0W-kfTRnUrJ6XyKNR02gxI1sbj4H1Ge5g")

  ;;         Platform.isIOS (when apnsToken (await (FirebaseMessaging.instance.getToken)))

  ;;         :else (await (FirebaseMessaging.instance.getToken)))]
  ;;   token)
  )

(defn register! []
  (rd/reg-event-fx
   ::refresh-notes
   (fn [{:keys [db]} _]
     {:db db
      ::fetch-notes []}))

  (rd/reg-fx
   ::load-fcm-fx
   (fn [_]
     (when (not kIsWeb)
       (await (request-notification-permission)))))

  (rd/reg-fx
   ::schedule-alarm-fx (fn [m] (schedule-alarm m)))

  (rd/reg-event-fx ::schedule-alarm
                   (fn [{:keys [db]} [_ section-id]]
                     (let [section (get-in db [:current-note :sections section-id])]
                       {:db db
                        ::schedule-alarm-fx {:content (section "content")
                                             :note-id (get-in db [:current-note
                                                                  :id])
                                             :section section
                                             :section-id section-id
                                             :section-name (section "name")
                                             :description (section "description")
                                             :alarm-id (.hashCode (section "id"))}})))

  (rd/reg-event-fx
   ::load-fcm
   (fn [{:keys [db]} _]
     {:db db
      ::load-fcm-fx []}))

  (rd/reg-event-fx ::update-user-options
                   (fn [{:keys [db]} [_ opts]]
                     {:db db
                      ::storage-set-user-options opts}))
  (rd/reg-event-fx ::save-notes-event-fx
                   (fn [{:keys [db]} [_ notes]]
                     {:db db
                      ::save-notes notes}))

  (rd/reg-fx ::save-notes
             (fn [notes]

               (let [fdb (fdb/FirestoreDB)
                     {uid :user-id
                      email :email} (current-user)]
                 (await
                  (Future.wait
                   (mapv (fn [note]
                           (let [reminders (note-reminders note)
                                 note' (w/stringify-keys
                                        (update note
                                                :roles
                                                #(or % {uid "owner"})))]
                             (if reminders
                               (.insertNote fdb
                                            note'
                                            uid
                                            (:id note)
                                            email
                                            .updateUpdatedAt false
                                            .reminders reminders)
                               (.insertNote fdb
                                            note'
                                            uid
                                            (:id note)
                                            email
                                            .updateUpdatedAt false))))
                         notes))))))

  (rd/reg-event-fx ::migrate-all-notes-from-anonymous
                   (fn [{:keys [db]} [_ uid]]
                     ;;First, simple and fast check to see if we even need to migrate.
                     ;;If the user is owner of their latest note they weren't just an anonymous user.
                     (when (and
                            ;;The first note was not written by a registered user
                            ;;=> the last user to have written the note was anonymous
                            (not (:registered? (first (:notes db))))
                            (some? (:owner (first (:notes db)))))
                       (let [notes (into []
                                         (keep (fn [n]
                                                 ;;Then
                                                 (when (and
                                                        (not= (:owner n) uid)
                                                        (not-any?
                                                         #(= uid %) (:user_access n)))
                                                   (-> n
                                                       (assoc :id (str (random-uuid)))
                                                       (assoc :owner uid)
                                                       (update :user_access #(conj % uid))
                                                       (update :roles {uid "owner"}))))
                                               (:notes db)))]
                         {:db db
                          ::save-notes notes}))))

