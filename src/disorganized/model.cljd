  (rd/reg-fx ::save-list-widget
             (fn [{:keys [section stored-section-id stored-note-id color]}]
               (when
                (and (not kIsWeb)
                     Platform.isAndroid)
                 (when (and stored-note-id
                            stored-section-id
                            (= stored-section-id (section "id")))
                   (await (HomeWidget.saveWidgetData
                           "todo_list"
                           (c/jsonEncode
                            (assoc
                             section :color color))))

                   (await (HomeWidget.updateWidget
                           .androidName "NoteWidgetReceiver"))))))

