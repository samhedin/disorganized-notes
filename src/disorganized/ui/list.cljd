(ns disorganized.ui.list
  (:require
   ["package:cloud_firestore/cloud_firestore.dart" :refer [FirebaseFirestore SetOptions FieldValue]]
   ["dart:convert" :as c]
   ["package:disorganized_notes/utils.dart" :as dutils]
   ["dart:io" :refer [Platform]]
   ["package:home_widget/home_widget.dart" :refer [HomeWidget]]
   ["package:shared_preferences/shared_preferences.dart" :as sp]
   ["package:flutter/foundation.dart" :refer [kIsWeb kDebugMode FlutterError]]
   ["package:firebase_crashlytics/firebase_crashlytics.dart" :refer [FirebaseCrashlytics]]

   ["package:disorganized_notes/IndentableListItem.dart" :refer [IndentableListItem]]
   ["package:flutter/services.dart" :as svc]
   ["package:url_launcher/url_launcher.dart" :as url]
   [disorganized.ui.theme :as theme]
   ["package:flutter/widgets.dart" :as f_widgets]
   [clojure.set :refer [union]]
   [clojure.string :as string]
   [disorganized.model :as model]
   [disorganized.ui.popup :as popup]
   [hti.re-dash.alpha :as rd]
   [disorganized.model :as utils]
   ["package:flutter/material.dart" :as m]
   ["package:firebase_ai/firebase_ai.dart" :as ai]
   [cljd.flutter :as f]))

(def schema
  (let [data (ai/Schema.string
              .description "The item text")
        child-schema (ai/Schema.array
                      .nullable true
                      .items
                      (ai/Schema.object
                       .description "One item, optionally with children"
                       .properties
                       (dutils/stringKeys
                        {"data" data
                         "children"
                         (ai/Schema.array
                          .items (ai/Schema.object
                                  .description "One item"
                                  .properties (dutils/stringKeys
                                               {"data" data}))
                          .nullable true)})))]
    (ai/Schema.object
     .properties
     (dutils/stringKeys
      {"items"
       (ai/Schema.array
        .items (ai/Schema.object
                .description "One item, optionally with children"
                .properties
                (dutils/stringKeys
                 {"data" data
                  "children" child-schema})))}))))

(defn add-ids [item]
  {"data" (item "data")
   "children" (mapv #(add-ids %) (item "children"))
   "id" (str (random-uuid))})

(defn parse-response [response]
  (mapv add-ids (response "items")))

(defn ai-create [prompt]
  (let [model (.generativeModel (ai/FirebaseAI.googleAI)
                                .model model/gemini-model
                                .generationConfig
                                (ai/GenerationConfig
                                 .responseMimeType "application/json"
                                 .responseSchema schema))

        response (await (.generateContent model [(ai/Content.text prompt)]))
        response (model/dart->clj-ds (c/jsonDecode (.-text response)))]
    (parse-response response)))

(defn ai-modify [ctx section]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator m/ScaffoldMessenger]
    :get {{tthm .-textTheme} m/Theme}
    :managed [tc (m/TextEditingController)]
    :watch [current-note (rd/subscribe [::model/current-note])]
    :watch [brightness (rd/subscribe [::model/get-brightness])]
    :watch [premium? (rd/subscribe [::model/premium?])]

    :watch [prefs (rd/subscribe [::model/prefs])]

    (m/AlertDialog
     .content
     (m/Column
      .mainAxisSize m/MainAxisSize.min
      .crossAxisAlignment m/CrossAxisAlignment.start
      .children
      (concat
       [(m/Align
         .alignment m/Alignment.center
         .child (m/Text "Update list with AI"
                        .style (.-titleMedium tthm)))]

       [(f/widget
         :padding {:vertical 12}
         (m/Text "This will share this note with a third party AI provider.
Click Cancel if you're not cool with that."
                 .style (.merge
                         (.-bodySmall tthm)
                         (theme/faded-text-style brightness))))
        (m/TextField
         .maxLength 300
         .decoration (m/InputDecoration
                      .hintText "Write modification"
                      .hintStyle (.-bodySmall tthm))
         .controller tc)]))

     .actions [(m/TextButton
                .onPressed #(.pop navigator)
                .child (m/Text "Cancel"))

               (m/TextButton
                .onPressed (fn []
                             (.pop navigator)
                             (rd/dispatch [::model/set-key :ai-generating-section true])

                             (let [items (mapv (fn [x]
                                                 (dissoc x "id"))
                                               (section "content"))

                                   checked-items (mapv (fn [x]
                                                         (dissoc x "id"))
                                                       (section "checked-content"))
                                   new-list (await (ai-create
                                                    (str "Modify this list according to instructions"
                                                         items
                                                         "\n"
                                                         checked-items
                                                         "\n"
                                                         "Prompt"
                                                         "\n"
                                                         (.-text tc))))]
                               (rd/dispatch
                                [::model/update-current-note
                                 (fn [m]
                                   (assoc-in m [:sections (section "id") "content"] new-list))]))
                             (rd/dispatch [::model/set-key :ai-generating-section false]))

                .child (m/Text "Modify list"))]))))

(defn set-home-screen-widget [ctx note-id section]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    :let [section-id (section "id")]
    (m/AlertDialog
     .content
     (m/Text "Make list into a widget?

- You can only have one widget.
- On supported launchers the widget will be added.")

     .actions [(m/TextButton
                .child (m/Text "Cancel")
                .onPressed (fn []
                             (.pop navigator)
                             nil))
               (m/TextButton
                .onPressed (fn []
                             (let [prefs (await (sp/SharedPreferences.getInstance))
                                   ssection (c/jsonEncode (dutils/recursivelyStringifyKeys section))
                                   pin-request? (await (HomeWidget.isRequestPinWidgetSupported))]
                               (await (.setString
                                       prefs
                                       "note-id"
                                       note-id))

                               (await (.setString
                                       prefs
                                       "section-id"
                                       section-id))

                               (await (.setString prefs "todo_list" ssection))

                               (rd/dispatch [::model/load-home-screen-widget-data])

                               (await (HomeWidget.saveWidgetData "todo_list" ssection))
                               (await (HomeWidget.updateWidget
                                       .androidName "NoteWidgetReceiver"))

                               (when pin-request?
                                 (HomeWidget.requestPinWidget
                                  .androidName "NoteWidgetReceiver")))

                             (.pop navigator)
                             nil)
                .child (m/Text "Ok"))]))))

(defn text->list [ctx section-id]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    :get {{tthm .-textTheme} m/Theme}
    :managed [tc (m/TextEditingController)]
    (m/AlertDialog
     .content
     (m/SingleChildScrollView
      .child (m/Column
              .spacing 10
              .mainAxisSize m/MainAxisSize.min
              .children
              (concat
               [(m/Text "Import list"
                        .style (.-titleLarge tthm))

                (m/Text "Enter text you want to make into a list, will be split on newlines. 
Leading \"-\" will be stripped."
                        .style (.-bodyLarge tthm))
                (m/TextField
                 .decoration (m/InputDecoration
                              .hintText "Item1\nItem2\nItem3")
                 .maxLines nil
                 .minLines 3
                 .controller tc)])))

     .actions [(m/TextButton
                .onPressed #(.pop navigator)
                .child (m/Text "Cancel"))
               (m/TextButton
                .onPressed (fn []
                             (let [lines (filter #(not (string/blank? %))
                                                 (string/split (.-text tc) #"\n"))]
                               (rd/dispatch [::model/update-current-note
                                             (fn [m]
                                               (update-in m [:sections section-id "content"]
                                                          #(concat %
                                                                   (map (fn [l]
                                                                          {"id" (str (random-uuid))
                                                                           "children" []
                                                                           "data" (string/trim
                                                                                   (if (string/starts-with? l "-")
                                                                                     (subs l 1)
                                                                                     l))}) lines))))]))
                             (.pop navigator))
                .child (m/Text "Parse!"))]))))

