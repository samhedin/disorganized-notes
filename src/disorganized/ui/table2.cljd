(defn ai-modify [ctx section]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator m/ScaffoldMessenger]
    :get {{hcolor .-textTheme} m/Theme}
    :managed [tc (m/TextEditingController)]
    :watch [current-note (rd/subscribe [::model/current-note])]
    :watch [brightness (rd/subscribe [::model/get-brightness])]
    :watch [premium? (rd/subscribe [::model/premium?])]
    :watch [prefs (rd/subscribe [::model/prefs])]
    (m/AlertDialog
     .content
     (m/Column
      .mainAxisSize m/MainAxisSize.min
      .crossAxisAlignment m/CrossAxisAlignment.start
      .children
      (concat
       [(m/Align
         .alignment m/Alignment.center
         .child (m/Text "Update table with AI"
                        .style (.-titleMedium hcolor)))]

       [(f/widget
         :padding {:vertical 12}
         (m/Text "This will share this note with a third party AI provider.
Click Cancel if you're not cool with that."
                 .style (.merge
                         (.-bodySmall hcolor)
                         (theme/faded-text-style brightness))))
        (m/TextField
         .maxLength 300
         .decoration (m/InputDecoration
                      .hintText "Write modification"
                      .hintStyle (.-bodySmall hcolor))
         .controller tc)]))

     .actions [(m/TextButton
                .onPressed #(.pop navigator)
                .child (m/Text "Cancel"))

               (m/TextButton
                .onPressed (fn []
                             (.pop navigator)
                             (rd/dispatch [::model/set-key :ai-generating-section true])

                             (let [column-ids (mapv (fn [col] (col "cid"))
                                                    (section "columns"))
                                   old-rows (map #(let [data (% "data")]
                                                    (mapv (fn [cid] (data cid)) column-ids))
                                                 (section "content"))

                                   old-columns (mapv (fn [{:strs [name]}]
                                                       name)
                                                     (section "columns"))

                                   {:keys [columns rows text? name]}
                                   (await (ai-create (str
                                                      "Existing columns: "
                                                      old-columns
                                                      "\nExisting rows: "
                                                      old-rows
                                                      "\n"
                                                      (.-text tc))))]
                               (rd/dispatch
                                [::model/update-current-note
                                 (fn [m]
                                   (let [section' (assoc section
                                                         "columns" columns
                                                         "content" rows)]
                                     (update m :sections
                                             #(assoc % (section "id") section'))))]))
                             (rd/dispatch [::model/set-key :ai-generating-section false]))

                .child (m/Text "Modify table"))]))))

(def schema
  (ai/Schema.object
   .properties
   (dutils/stringKeys
    {"columns"
     (ai/Schema.array
      .items (ai/Schema.string
              .description "All columns that are in the table."))

     "rows" (ai/Schema.array
             .description "An array of rows. Each row is an array of values ordered according to the columns array."
             .items (ai/Schema.array
                     .description "A row of values"
                     .items (ai/Schema.string
                             .description "A value")))

     "name" (ai/Schema.string
             .description "The name of the table. Keep it short and general.")

     "text" (ai/Schema.string
             .description "Any additional text"
             .nullable true)})

   .optionalProperties ["text"]))

;; {columns [Breed Temperament Defining Cute Feature], name Cute Dog Breeds, text A subjective list of some famously cute dog breeds and their characteristics., rows [[Pomeranian Playful, Extroverted Fluffy ball of fur] [Corgi Affectionate, Smart Stubby legs and big smile] [Golden Retriever Friendly, Intelligent Golden coat and happy face] [French Bulldog Adaptable, Playful Large bat-like ears] [Shiba Inu Charming, Fearless Curled tail and foxy face]]}
(defn schema-response->table [response]
  (let [columns (mapv (fn [name]
                        {"cid" (str (random-uuid))
                         "name" name})
                      (response "columns"))
        rows (mapv (fn [row]
                     {"id" (str (random-uuid))
                      "data" (into {}
                                   (map (fn [{:strs [cid]} data]
                                          [cid data])
                                        columns row))})
                   (response "rows"))]

    {:columns columns
     :rows rows
     :text? (response "text")
     :name (response "name")}))

(defn ai-create [prompt]
  (let [model (.generativeModel (ai/FirebaseAI.googleAI)
                                .model model/gemini-model
                                .generationConfig
                                (ai/GenerationConfig
                                 .responseMimeType "application/json"
                                 .responseSchema schema))

        response (await (.generateContent model [(ai/Content.text prompt)]))]
    (schema-response->table (model/dart->clj-ds (c/jsonDecode (.-text response))))))

(defn escape-csv-value [v]
  (let [s (str v)]
    (if (or (clojure.string/includes? s ",")
            (clojure.string/includes? s "\"")
            (clojure.string/includes? s "\n"))
      (str "\"" (clojure.string/replace s "\"" "\"\"") "\"")
      s)))

(defn export-csv [columns rows]
  (let [column-ids (mapv #(% "cid") columns)
        header (mapv #(% "name") columns)
        data-rows (mapv (fn [row]
                          (mapv #(get-in row ["data" %]) column-ids))
                        rows)
        all-rows (cons header data-rows)
        csv-lines (map (fn [row]
                         (clojure.string/join "," (map escape-csv-value row)))
                       all-rows)]
    (clojure.string/join "\n" csv-lines)))
(defn row-reduction [ctx columns section-id & [reduction?]]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]

    :let [constant? (when reduction?
                      (reduction? "constant"))
          previously-selected? (if reduction?
                                 (into #{}
                                       (reduction? "columns"))
                                 #{})

          operation-id? (when reduction?
                          (reduction? "operation-id"))]

    :get {{hcolor .-textTheme} m/Theme}

    :managed [tc (if constant?
                   (m/TextEditingController
                    .text (str constant?))
                   (m/TextEditingController))]

    ;;Selected columns
    :watch [selected (atom previously-selected?) :as *selected]
    :watch [brightness (rd/subscribe [::model/get-brightness])]

    (m/AlertDialog
     .content
     (m/Column
      .mainAxisSize m/MainAxisSize.min
      .children
      [(m/Text "Select columns to include in calculation")
       (m/SizedBox .height 10)
       (m/Row
        .mainAxisAlignment m/MainAxisAlignment.center
        .children
        (mapv (fn [{:strs [cid name]}]
                (f/widget
                 :padding {:right 5}
                 (m/FilterChip
                  .selected (contains? selected cid)
                  .shape (m/RoundedRectangleBorder
                          .borderRadius (m/BorderRadius.circular 10))
                  .side (m/BorderSide .width 0.4
                                      .color (.-color (.-titleLarge hcolor)))
                  .label (m/Text name)
                  .onSelected (fn [selected?]
                                (if selected?
                                  (swap! *selected #(conj % cid))
                                  (swap! *selected #(disj % cid))))))) columns))
       (m/TextField
        .decoration (m/InputDecoration
                     .hintText "Optional: Include constant"
                     .hintStyle (.merge
                                 (.-bodySmall hcolor)
                                 (theme/faded-text-style brightness)))
        .controller tc)])
     .actions
     [(m/TextButton
       .onPressed (fn []
                    (.pop navigator))

       .child (m/Text "Cancel"))
      (m/TextButton
       .child (m/Text "Multiply")
       .onPressed
       (fn []
         (let [constant? (try
                           (double.parse (or (.-text tc) "1"))
                           (catch FormatException e
                             nil))]
           (add-row-calculation "multiply" selected section-id constant?
                                operation-id?))

         (.pop navigator)))

      (m/TextButton
       .child (m/Text "Sum")
       .onPressed
       (fn []
         (add-row-calculation "sum" selected section-id
                              (try
                                (double.parse (or (.-text tc) "0"))
                                (catch FormatException e
                                  nil))
                              operation-id?)

         (.pop navigator)))]))))

(defn column-reduction-options [ctx column section-id]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    (m/AlertDialog
     .content
     (m/Text (str "Calculate on " (column "name")))
     .actions
     [(m/TextButton.icon
       .icon (m/Icon m/Icons.add)
       .label (m/Text "Sum")
       .onPressed
       (fn []

         (rd/dispatch [::model/update-current-note
                       (fn [m]
                         (update-in m [:sections section-id "calculations"]
                                    #(assoc % (column "cid") "sum")))])
         (.pop navigator)))

      (m/TextButton.icon
       .icon (m/Icon m/Icons.clear)
       .label (m/Text "Multiply")
       .onPressed
       (fn []
         (rd/dispatch [::model/update-current-note
                       (fn [m]
                         (update-in m [:sections section-id "calculations"]
                                    #(assoc % (column "cid") "multiply")))])
         (.pop navigator)))

      (m/TextButton.icon
       .icon (m/Icon m/Icons.minimize)
       .onPressed
       (fn []
         (rd/dispatch [::model/update-current-note
                       (fn [m]
                         (update-in m [:sections section-id "calculations"]
                                    #(dissoc % (column "cid"))))])
         (.pop navigator))

       .label (m/Text "Nothing"))]))))

(defn column-selector [columns ctx]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    :get {{hcolor .-textTheme} m/Theme}

    (m/AlertDialog
     .content
     (m/Column
      .mainAxisSize m/MainAxisSize.min
      .children
      (concat
       [(m/Text "Select column to sum/multiply"
                .style (.-bodyLarge hcolor))]
       (mapv (fn [c]
               (m/TextButton
                .onPressed
                (fn []

                  (.pop navigator c))
                .child (m/Text (c "name")))) columns)))
     .actions [(m/TextButton
                .child (m/Text "Cancel")
                .onPressed (fn []
                             (.pop navigator)))]))))

