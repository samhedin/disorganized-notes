                 .leading (m/Icon m/Icons.alarm)))

(defn notification-permission [ctx]
  (when (not (await (.isNotificationAllowed (notif/AwesomeNotifications))))
    (m/showDialog
     .context ctx
     .builder
     (f/build
      :get [m/Navigator]
      :get {{tthm .-textTheme} m/Theme}

      (m/AlertDialog
       .content
       (m/Column
        .mainAxisSize m/MainAxisSize.min

        .spacing 12
        .children
        [(m/Text "Notification permissions"
                 .style (.-titleLarge tthm))

         (m/Text "Grant notification permissions to receive reminders"
                 .style (.-bodyLarge tthm))])
       .actions
       [(m/TextButton
         .child (m/Text "Grant notification permissions")
         .onPressed (fn []
                      (model/request-notification-permission true)
                      (.pop navigator)
                      nil))
        (m/TextButton
         .onPressed (fn []
                      (.pop navigator))
         .child (m/Text "Cancel"))])))))

(defn magic [ctx]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator m/ScaffoldMessenger m/MediaQuery]
    :get {{tthm .-textTheme} m/Theme}
    :managed [tc (m/TextEditingController)]
    :watch [current-note (rd/subscribe [::model/current-note])]
    :watch [brightness (rd/subscribe [::model/get-brightness])]

    :watch [prefs (rd/subscribe [::model/prefs])]

    (m/AlertDialog
     .content
     (m/Container
      .width (- (-> media-query .-size .-width) 100)
      .child 
      (m/Column
       .mainAxisSize m/MainAxisSize.min
       .crossAxisAlignment m/CrossAxisAlignment.start
       .children
       [(m/Align
         .alignment m/Alignment.center
         .child (m/Text "Generate a section using AI"
                        .style (.-titleMedium tthm)))
        (m/TextField
         .maxLines nil
         .minLines 3
         .autocorrect true
         .textCapitalization m/TextCapitalization.sentences
         .maxLength 5000
         .decoration (m/InputDecoration
                      .hintText "Examples: 
- Make a leg workout
- Convert this recipe to metric"
                      .hintStyle (.-bodySmall tthm))
         .controller tc)
        (m/Text "Select what to generate"
                .style (.-titleMedium tthm))
        (m/SizedBox .height 12)
        (m/TextButton.icon
         .onPressed (fn []
                      (.pop navigator)
                      (model/log-analytics "ai_gen" {"type" "table"})
                      (rd/dispatch [::model/set-key :ai-generating-section true])
                      (let [{:keys [columns rows text? name]} (await (table2/ai-create (.-text tc)))]
                        (rd/dispatch
                         [::model/update-current-note
                          (fn [m]
                            (let [text-section? (when text?
                                                  (assoc (model/default-section-map
                                                          "text"
                                                          (count (:sections m))
                                                          "text")
                                                         "content" text?))

                                  section (model/default-section-map
                                           "table2"
                                           (if text?
                                             (inc (count (:sections m)))
                                             (count (:sections m)))
                                           name)
                                  section' (assoc section
                                                  "columns" columns
                                                  "content" rows)

                                  with-table (update m :sections
                                                     #(assoc % (section "id") section'))]
                              (if text-section?
                                (update with-table :sections #(assoc % (text-section? "id") text-section?))
                                with-table)))]))
                      (rd/dispatch [::model/set-key :ai-generating-section false])
                      nil)

         .label (m/Text "Table & text")
         .icon (m/Icon m/Icons.table_chart))

        (m/SizedBox .height 12)

        (m/TextButton.icon
         .icon (m/Icon m/Icons.format_list_bulleted)

         .onPressed (fn []
                      (model/log-analytics "ai_gen" {"type" "list"})
                      (rd/dispatch [::model/set-key :ai-generating-section true])
                      (.pop navigator)
                      (let [list (await (l/ai-create (.-text tc)))]
                        (rd/dispatch
                         [::model/update-current-note
                          (fn [m]
                            (let [section (model/default-section-map
                                           "list"
                                           (count (:sections m))
                                           "list")

                                  section' (assoc section "content" list)]
                              (update m :sections
                                      #(assoc % (section "id") section'))))]))
                      (rd/dispatch [::model/set-key :ai-generating-section false])
                      nil)

         .label (m/Text "List"))

        (m/SizedBox .height 12)
        ;; (m/TextButton.icon
        ;;  .icon (m/Icon m/Icons.image)

        ;;  .onPressed (fn []
        ;;               (model/snackbar scaffold-messenger "Generating, stand by...")
        ;;               (.pop navigator)
        ;;               (let [image (await (media2/ai-create-image (.-text tc)))]

        ;;                 ))

        ;;  .label (m/Text "Image"))
        ]))

     .actions [(m/TextButton
                .onPressed #(.pop navigator)
                .child (m/Text "Cancel"))]))))

(defn add-section [section-type  ctx section-list-controller scroll-controller]
  (utils/log-analytics "section_added" {"type" section-type})
  (rd/dispatch [::model/reset-restructure-mode])

  (when (and (not kIsWeb) (= section-type "reminder"))
    (await (notification-permission ctx)))

  (let [index (atom nil)]
    (rd/dispatch [::model/update-current-note
                  (fn [m]
                    (let [number-of-existing-sections (count (:sections m))
                          _ (reset! index  number-of-existing-sections)
                          updated-name (ensure-unique-name
                                        m
                                        section-type number-of-existing-sections)

                          section-map  (model/default-section-map section-type number-of-existing-sections updated-name)

                          id (section-map "id")

                          new-note (update m :sections #(assoc %
                                                               id
                                                               section-map))]
                      (rd/dispatch [::model/set-key :recently-added-section id])

                      (when (= "list" section-type)
                        (rd/dispatch
                         [::model/set-recently-added-item
                          ((first (get-in new-note [:sections id "content"])) "id")]))
                      new-note))])
    
    (Future/delayed
     (Duration .milliseconds 50)
     (fn []
       (println "jumping " section-list-controller scroll-controller @index)
       
       (.animateToItem section-list-controller
                    .scrollController scroll-controller
                    .index @index
                    .alignment 0.0
                    .duration (fn [distance]
                                (Duration .milliseconds (min (/ distance 2)
                                                             1000)))
                    .curve (fn [distance]
                             m/Curves.easeInOut))))))

(defn bindings [ctx section-menu-globalkey section-list-controller scroll-controller]
  {(m/SingleActivator
    svc/LogicalKeyboardKey.f1
    .alt true)
   (fn []
     (m/showDialog
      .context ctx
      .builder
      (f/build
       :get [m/Navigator]
       :get {{tthm .-textTheme} m/Theme}

       (m/AlertDialog
        .content
        (m/Column
         .crossAxisAlignment m/CrossAxisAlignment.start
         .mainAxisSize m/MainAxisSize.min
         .spacing 10
         .children
         [(m/Text "Shortcuts"
                  .style (.-titleLarge tthm))
          (m/Text "If not responding to keypresses, press tab to give the window focus"
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+f1: " "Open this view")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+t: " "Add Table")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+l: " "Add List")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+e: " "Add Text")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+r: " "Add Reminder")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+m: " "Add Media")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+v: " "Add Voice")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+i: " "Add Timer")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+a: " "Add Alarm")
                  .style (.-bodyLarge tthm))

          (m/Text (str "alt+g: " "AI Generate")
                  .style (.-bodyLarge tthm))])

        .actions [(m/TextButton
                   .child (m/Text "Ok")
                   .onPressed #(.pop navigator))]))))
   (m/SingleActivator
    svc/LogicalKeyboardKey.keyS
    .alt true)
   (fn []
     (.showButtonMenu (.-currentState section-menu-globalkey)))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyT
    .alt true)
   (fn []
     (add-section "table2" ctx section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyL
    .alt true)
   (fn []
     (add-section "list" ctx  section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyE
    .alt true)
   (fn []
     (add-section "text" ctx  section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyR
    .alt true)
   (fn []
     (add-section "reminder" ctx  section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyM
    .alt true)
   (fn []
     (add-section "media2" ctx  section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyV
    .alt true)
   (fn []
     (add-section "voice" ctx  section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyI
    .alt true)
   (fn []
     (add-section "timer" ctx  section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyA
    .alt true)
   (fn []
     (add-section "Alarm" ctx  section-list-controller scroll-controller))

   (m/SingleActivator
    svc/LogicalKeyboardKey.keyG
    .alt true)
   (fn []
     (magic ctx))})

(defn clone-button-onpressed [navigator m scaffold-messenger premium? ctx]
  (model/unfocus-then-run
   (.pop navigator)
   (let [new-note (await (utils/clone-note m scaffold-messenger premium?))]
     (when new-note
       
       (-> ctx go_router/GoRouterHelper
           (.pushNamed  "edit"
                        .pathParameters {"id" (:id new-note)}
                        .extra {:autofocus false}))
       (rd/dispatch [::model/reset-restructure-mode])
       (rd/dispatch [::model/reset-undo-stack])
       (rd/dispatch [::model/upload-note [new-note true]])
       (rd/dispatch
        [::model/set-current-note-id (:id new-note)])

       (rd/dispatch [::model/set-new-plaintext (:plaintext new-note)])
       (rd/dispatch [::model/set-key :override-title (:title new-note)])
       (.showSnackBar scaffold-messenger
                      (m/SnackBar
                       .content (m/Text "Copy content from parent?")
                       .persist false
                       .action
                       (m/SnackBarAction
                        .label "Yes"
                        .onPressed
                        (fn []

                          (let [pt
                                (or (utils/get-new-plaintext (:plaintext m)) "")]
                            (rd/dispatch [::model/set-new-plaintext pt])
                            (rd/dispatch [::model/set-key :override-title (:title m)])
                            (rd/dispatch
                             [::model/update-current-note
                              (fn [n]
                                (assoc n
                                       :title (:title m)
                                       :sections (utils/reset-checkboxes m)
                                       :plaintext pt))]))))))
       nil))))

(defn title-widget [plaintext-focus tc focus tutorial?]
  (f/widget
   :get {{tthm .-textTheme} m/Theme}
   :padding {:horizontal 12}
   :watch [brightness (rd/subscribe [::model/get-brightness])]
   :bg-watcher ([focused? focus :> .-hasFocus]
                (when (not focused?)
                  (rd/dispatch
                   [::model/update-current-note
                    #(assoc % :title (string/trim (.-text tc)))])))
   (m/TextField
    .style (.-titleLarge tthm)
    .decoration (m/InputDecoration
                 .hintText (if tutorial? "Title of your first note" "Title")
                 .hintStyle (theme/faded-text-style brightness)
                 .border m/InputBorder.none)
    .autocorrect true
    .enableSuggestions true

    .textCapitalization m/TextCapitalization.sentences
    .focusNode focus
    .maxLines 1
    .controller tc
    .onSubmitted (fn [text]
                   (.requestFocus plaintext-focus)))))

(defn clone-icon [tthm note]
  (m/SliverVisibility
   .visible (boolean (:clone-tutorial note))
   .sliver
   (m/SliverPadding
    .padding (m/EdgeInsets.symmetric .vertical 10
                                     .horizontal 10)
    .sliver (m/SliverToBoxAdapter
             .child (m/Column
                     .crossAxisAlignment m/CrossAxisAlignment.start
                     .children
                     [(m/Text "Tutorial "
                              .style (.-titleLarge tthm))
                      (m/Text "Reuse the template by cloning this note"
                              .style (.-bodyLarge tthm))
                      (m/Row
                       .children [(m/Text "Clone icon (top left): ")
                                  (m/Icon m/Icons.copy_all
                                          .size 25)])])))))

(defn links [tthm]
  (m/SliverToBoxAdapter
   .child
   (model/links tthm)))

(defn body-widget [plaintext-tc focus tutorial?]
  (f/widget
   :get {{tthm .-textTheme} m/Theme}

   :managed [*prev (atom "") :dispose nil]
   :padding {:horizontal 12}

   :watch [brightness (rd/subscribe [::model/get-brightness])]
   :bg-watcher ([focused? focus :> .-hasFocus]

                (when (not focused?)
                  (rd/dispatch
                   [::model/update-current-note
                    #(assoc % :plaintext (string/trim (.-text plaintext-tc)))])))

   (m/TextField
    .style (.-bodyLarge tthm)
    .focusNode focus
    .controller plaintext-tc
    .autocorrect true
    .enableSuggestions true

    .keyboardType m/TextInputType.multiline
    .textAlignVertical m/TextAlignVertical.top
    .textCapitalization m/TextCapitalization.sentences
    .onChanged (fn [text]
                 (maintain-enumeration text *prev plaintext-tc))

    .decoration
    (m/InputDecoration
     .border m/InputBorder.none
     .focusedBorder m/InputBorder.none
     .enabledBorder m/InputBorder.none
     .hintText (if tutorial? "Free text goes here!" "Free text")
     .hintStyle (theme/faded-text-style brightness))
    .onTapOutside
    (fn [_]
      (.unfocus (.-primaryFocus (.instance m/FocusManager))))
    .minLines 1
    .maxLines nil)))

(defn last-updated-widget [note]
  (f/widget
   :get {{tthm .-textTheme} m/Theme}
   :get [:timeformat-24-hours?]
   :padding {:top 12
             :bottom 12}
   :watch [brightness (rd/subscribe [::model/get-brightness])]
   (m/Align
    .alignment m/Alignment.bottomLeft)
   (m/Text (str "Updated: "
                (df/DateFormatter.getVerboseDateTimeRepresentation
                 (if-let
                  [created_at (:created_at note)]
                   (try
                     (let [^Timestamp ca created_at]
                       (.toLocal (.toDate ca)))
                     (catch dynamic e
                       (DateTime.now)))
                   (DateTime.now))
                 timeformat-24-hours?))
           .style (.merge
                   (.-bodySmall tthm)
                   (theme/faded-text-style brightness)))))

(defn reorder-sections-mode []
  (f/widget
   :watch [sorted-sections- (rd/subscribe [::model/current-sorted-sections])
           sorted-sections (atom sorted-sections-) :as *sorted-sections
           reorder-sections (rd/subscribe [::model/reorder-sections?])
           :refresh-on sorted-sections]

   (m/ReorderableListView.builder
    .header (m/ElevatedButton.icon
             .style (m/ElevatedButton.styleFrom
                     .elevation 3
                     .shape (m/RoundedRectangleBorder
                             .borderRadius (m/BorderRadius.circular 15))

                     .side (m/BorderSide
                            .style (m/BorderStyle.none)))
             .label (m/Text "Done")
             .icon (m/Icon m/Icons.done)
             .onPressed (fn []
                          (rd/dispatch [::model/reset-restructure-mode])
                          (rd/dispatch [::model/set-key :reorder-sections? false])))
    .buildDefaultDragHandles false
    ;; .onReorderStart (fn [_]
    ;;                   (.unfocus (.-primaryFocus (.instance m/FocusManager))))
    .shrinkWrap true
    .itemCount (count sorted-sections)
    .itemBuilder
    (fn [_ index]
      (let [[section-id section] (nth sorted-sections index)]
        (model/log-crashlytics (str "reordering show " section-id " - " (section "type")))
        (m/ListTile
         .key (m/ValueKey section-id)
         .leading  (m/ReorderableDragStartListener
                    .key (m/ValueKey (str section-id "dragstartlistenerrrr"))
                    .index index
                    .child (m/Icon m/Icons.drag_indicator))
         .title (m/Text (str (section "name") ": "
                             (string/capitalize
                              (str (case (section "type")
                                     "table2" "table"
                                     "media2" "media/draw"
                                     (section "type")))))))))

    .onReorder (fn [oldindex newindex]
                 (move-section-index oldindex newindex *sorted-sections)))))

(defn add-tag [tag]
  (let [tag (string/trim tag)]
    (rd/dispatch [::model/update-current-note
                  (fn [m]
                    (update
                     m
                     :tags
                     #(let [tag (if (= \# (first tag))
                                  (subs tag 1 (count tag))
                                  tag)]

                        (if (or ((into #{} %) tag) (string/blank? tag))
                          %
                          (into [] (conj % tag))))))])))

(defn tags [note]
  (f/widget
   :watch [brightness (rd/subscribe [::model/get-brightness])
           {:keys [all-tags]} (rd/subscribe [::model/all-tags-sub])
           add-tag? (atom false) :as *add-tag?]

   :context ctx
   :managed [overlaycontroller (m/OverlayPortalController) :dispose nil]
   :get {{tthm .-textTheme} m/Theme}
   :get [:first-launch?]
   :let [style (.merge
                (.-bodySmall tthm)
                (theme/faded-text-style brightness))]

   (m/AnimatedSwitcher
    .duration (Duration .milliseconds 300)
    .child
    (if add-tag?
      ^#/(m/Autocomplete String)
      (m/Autocomplete
       .optionsViewOpenDirection m/OptionsViewOpenDirection.up

       .onSelected (fn [tag]
                     (add-tag tag)
                     (.hide overlaycontroller)
                     (reset! *add-tag? false))
       .fieldViewBuilder
       (fn [_ tc focus-node on-submitted]
         (f/widget
          :bg-watcher ([add-tag? *add-tag?]
                       (when add-tag?
                         (.requestFocus focus-node)))
          :padding {:horizontal 20}

          :bg-watcher ([focused? focus-node :> .-hasFocus]
                       (when (not focused?)
                         (add-tag (.-text tc))
                         (.hide overlaycontroller)
                         (reset! *add-tag? false)))
          :watch [first-tag? (rd/subscribe [::model/first-tag])]
          :managed [_ (do (m/WidgetsBinding.instance.addPostFrameCallback
                           (fn [_]
                             (when (and (string/blank? (.-text tc))
                                        (not (string/blank? first-tag?)))
                               (.-text! tc first-tag?))
                             nil))
                          nil) :dispose nil]
          (m/Align
           .alignment m/Alignment.centerLeft)
          (m/ConstrainedBox
           .constraints (m/BoxConstraints
                         .maxWidth 200))
          (m/OverlayPortal
           .controller overlaycontroller
           .overlayChildBuilder (fn [_]
                                  (m/Positioned
                                   .bottom (if kIsWeb (+ 100
                                                         (* (count all-tags) 25))
                                               (+ 420
                                                  (* (count all-tags) 25)))

                                   .child
                                   (m/Card
                                    .elevation 4.0
                                    .child
                                    (model/outline
                                     (f/widget
                                      :padding {:horizontal 12
                                                :vertical 12}
                                      (if first-tag?
                                        (m/Text "We've entered your first tag, just submit it!")
                                        (m/Text "Tags help you find notes later.
Writing a recipe? Add a recipe tag.")))
                                     0.4 2 20))))
           .child
           (m/TextField
            .onTapOutside (fn [_]
                            (model/unfocus-then-run
                             nil))
            .controller tc
            .focusNode focus-node
            .decoration (m/InputDecoration
                         .suffixIcon (m/IconButton
                                      .icon (m/Icon m/Icons.send)
                                      .onPressed
                                      (fn []
                                        (println "TAG ADDED " first-tag?)
                                        (when first-launch?
                                          
                                          (utils/log-analytics "onboarding_first_tag_inserted" {})
                                          (rd/dispatch [::model/set-key :enable-clone-highlight true]))

                                        (add-tag (.-text tc))
                                        (.hide overlaycontroller)
                                        (reset! *add-tag? false))))
            .onSubmitted (fn [tag]
                           (when first-launch?
                                          (println "setting enabel clone highlight")
                                          (utils/log-analytics "onboarding_first_tag_inserted" {})
                                          (rd/dispatch [::model/set-key :enable-clone-highlight true]))
                           (add-tag tag))))))

       .optionsViewBuilder (fn [ctx on-selected options]
                             (f/widget
                              :padding {:horizontal 0}
                              :watch [height-factor (atom 0.0) :as *height-factor
                                      visible? (atom true) :as *visible?]
                              :managed [_ (m/WidgetsBinding.instance.endOfFrame.then
                                           (fn [_]
                                             (reset! *height-factor 1.0))) :dispose nil]

                              :animate [height-factor height-factor
                                        :duration (Duration .milliseconds 150)
                                        :curve m/Curves.ease]
                              m/Material
                              (m/ConstrainedBox
                               .constraints (m/BoxConstraints .maxWidth 200
                                                              .maxHeight 300))
                              (m/TapRegion
                               .onTapOutside (fn [_]
                                               (reset! *visible? false)))
                              (m/Visibility
                               .visible visible?)
                              m/Card
                              (m/ListView.builder
                               .shrinkWrap true
                               .itemCount (count options)
                               .itemBuilder (fn [_ i]
                                              (m/ListTile
                                               .shape (m/RoundedRectangleBorder
                                                       .borderRadius theme/border-radius)
                                               .title (m/Text (nth options i)
                                                              .maxLines 1
                                                              .overflow m/TextOverflow.ellipsis)
                                               .onTap (fn []
                                                        (on-selected (nth options i))))))))
       .optionsBuilder
       (fn [^m/TextEditingValue {:flds [text]}]
         (let [^#/(Iterable String) result
               (into []
                     (filter (fn [^String x]
                               (string/includes? x text))
                             all-tags))]
           result)))

      (f/widget
       :watch [notes (rd/subscribe [::model/get-notes])
               premium? (rd/subscribe [::model/premium?])
               prefs (rd/subscribe [::model/prefs])
               brightness (rd/subscribe [::model/get-brightness])]
       :managed [tutorial? (and (every? :tutorial notes)
                                (not (:tutorial note))
                                (seq (:sections note))
                                (empty? (:tags note))) :dispose nil :refresh-on note]

       :let [allow? (or premium? (empty? (:tags note)))]
       :get [m/ScaffoldMessenger]
       :get {{cs .-colorScheme} m/Theme}

       (m/Row
        .children
        (concat
         [(let [button (m/SizedBox
                        .width 145
                        .child (m/ElevatedButton.icon
                                .label (m/Text "Tags")
                                .icon
                                (m/Icon (if allow?
                                          m/Icons.tag
                                          m/Icons.star_outline))

                                .onPressed (fn []
                                             (if allow?
                                               (do
                                                 (when (and (empty? (:tags note))

                                                            (every? :tutorial notes))
                                                   (.show overlaycontroller))
                                                 (swap! *add-tag? not))
                                               (model/prompt-to-paywall scaffold-messenger "More than one tag requires premium"))
                                             nil)))]
            (if tutorial?
              (model/outline button)  ;(model/outline section 0 2)
              button))]

         (when (seq (:tags note))
           (mapv #(m/TextButton
                   .onPressed (fn []
                                (popup/confirm
                                 ctx
                                 (str "Delete tag " % "?")
                                 (fn []
                                   (rd/dispatch
                                    [::model/update-current-note
                                     (fn [m]
                                       (update m :tags
                                               (fn [tags]
                                                 (into [] (filter (fn [tag]
                                                                    (not= tag %))) tags))))]))))
                   .child (m/Text %
                                  .style style)) (:tags note))))))))))

(defn show-section [section-id restructure-mode note-id section tutorial? *section-size section-name text-search type]
  (f/widget
   :key (str section-id restructure-mode "main-view")
   :bind {:section-id section-id
          :section section
          :section-name section-name}
   :padding {:top 12}
   :watch [{:strs [sections-start-expanded]} (rd/subscribe [::model/get-user-options])]
   :get [m/Theme :first-launch?]
   (m/Card
    .elevation 0.0)
   (m/Theme
    .data (.copyWith theme .dividerColor m/Colors.transparent)
    .child
    (m/ExpansionTile
     .tilePadding m/EdgeInsets.zero
     .initiallyExpanded (if (nil? sections-start-expanded)
                          true
                          sections-start-expanded)

     .showTrailingIcon false
     .title  (section-header
              note-id
              section-id
              section
              tutorial?
              *section-size)
     .children
     [(f/widget
       :padding {:horizontal 8
                 :bottom 12}
       (condp = type
         "text" (t/show section-id)
         "table" (table/show (section "id"))
         "table2" (table2/show (section "id")
                               text-search)
         "alarm" (alarm/show section-id section note-id)
         "location" (gps/show section-id section)
         "mindmap" (mindmap/show section-id)
         "timer" (timer/show section-id section)
         "draw" (draw/show section-id section)
         "list" (l/showlist section-id text-search)
         "reminder" (date/show section-id)
         "media" (media/show section-id)
         "media2" (media2/show section-id)

         "voice" (voice/show section-id note-id section-name)
         nil (assert false
                     (str "type was nil for " section))))]))))

