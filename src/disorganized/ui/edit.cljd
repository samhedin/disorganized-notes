(defn default-section-properties [{:keys [section-id]} section note-id *section-size]
  (f/widget
   :get {{cs .-colorScheme} m/Theme}
   :context ctx
   :get [m/ScaffoldMessenger]

   (m/Tooltip
    .message "Section settings"
    .child
    (m/PopupMenuButton
     .clipBehavior m/Clip.antiAlias
     .itemBuilder (fn [_]
                    #dart ^m/PopupMenuEntry
                     [(m/PopupMenuItem
                       .value "delete"
                       .child (m/Text "Delete section"))])
     .onSelected (fn [selection]
                   (case selection
                     "delete" (popup/delete-section
                               ctx
                               note-id
                               section-id
                               section
                               *section-size)))))))

(defn list-siblings [section-id section  premium? note-id restructure-mode? input *section-size]
  (concat
   (when (and (not kIsWeb) Platform.isAndroid restructure-mode?)
     [(f/widget
       :context ctx
       (m/IconButton
        .icon (m/Icon m/Icons.widgets)
        .onPressed
        (fn []
          (l/set-home-screen-widget ctx  note-id section))))])

   (when restructure-mode?
     [(f/widget
       :get [m/ScaffoldMessenger]

       (m/IconButton
        .onPressed (fn []
                     (.showSnackBar scaffold-messenger
                                    (m/SnackBar .content
                                                (m/Text (str "Checkboxes"
                                                             (if (section "checkboxes-visible") " off" " on")))))
                     (l/toggle-checkbox-visibility section-id)
                     nil)
        .icon (m/Icon (if (section "checkboxes-visible")
                        m/Icons.check_box_outline_blank
                        m/Icons.check_box_outlined))))])

   [(default-section-properties input section note-id *section-size)]))

(defn section-header-siblings [section  premium? note-id restructure-mode? *section-size]
  (let [id (section "id")
        input {:section-id id
               :name (section "name")
               :section-index (section "section-position")}]
    (case (section "type")

      "list" (l/properties note-id section *section-size)
      "table2" (table2/properties note-id section *section-size)
      "text" (t/properties note-id section *section-size)

      [(default-section-properties input section note-id *section-size)])))

(defn move-section-index [old-idx new-idx *sorted-sections]
  (let [sorted-sections
        (into []
              (sort-by (fn [[_ {:strs [section-position]}]]
                         section-position)
                       @*sorted-sections))

        new-sections (utils/vec-move
                      sorted-sections
                      old-idx
                      (if (< old-idx new-idx)
                        (dec new-idx)
                        new-idx))
        final-sections (into {}
                             (map-indexed
                              (fn [i [section-name section]]
                                [section-name (assoc section "section-position" i)])
                              new-sections))]
    (reset! *sorted-sections final-sections)
    (rd/dispatch
     [::model/update-current-note
      (fn [m]
        (assoc m :sections final-sections))])))

(defn section-header [note-id
                      section-id
                      section
                      tutorial?
                      *section-size]
  (f/widget
   :context ctx
   :get {{tthm .-textTheme} m/Theme}
   :managed [tc (m/TextEditingController)
             focus-node (m/FocusNode)
             _ (do (m/WidgetsBinding.instance.endOfFrame.then
                    (fn [_]
                      (when (string/blank? (.-text tc))
                        (.-text! tc (section "name"))))))
             :dispose nil]
   :watch [restructure-mode? (rd/subscribe [::model/get-restructure-mode section-id])]

   :watch [invalid (atom nil) :as *invalid
           restructure-mode? (rd/subscribe [::model/get-restructure-mode section-id])
           premium? (rd/subscribe [::model/premium?])]
   :padding {:horizontal 12} ;;to align with title and body

   :bg-watcher ([focused? focus-node :> .-hasFocus]
                (when focused?
                  (.-selection! tc (m/TextSelection
                                    .baseOffset 0
                                    .extentOffset (count (.-text tc)))))

                (when (and (not invalid) (not focused?))
                  (rename-section section-id (section "name") tc)))

   (m/Row
    .mainAxisAlignment m/MainAxisAlignment.start
    .children
    (concat
     (when (not restructure-mode?)
       [(m/IntrinsicWidth
         .child
         (m/TextField
          .maxLines 1
          .controller tc
          .textCapitalization m/TextCapitalization.sentences
          .focusNode focus-node
          .style (.-titleLarge tthm)
          .onChanged
          (fn [text]
            (rd/dispatch
             [::model/update-current-note
              (fn [m]
                (reset! *invalid
                        (cond
                          (and
                           (get-in m [:sections text])
                           (not= text (section "name"))) "Not unique"
                          (string/blank? text) "Not filled"
                          (< 30 (count text)) "Too long"
                          :else nil))
                m)]))

          .onSubmitted
          (fn [_]
            (when (not invalid)
              (.unfocus (.-primaryFocus (.instance m/FocusManager)))))

          .decoration (if invalid
                        (m/InputDecoration
                         .errorText invalid

                         .border (m/OutlineInputBorder))
                        (m/InputDecoration
                         .border m/InputBorder.none))))])
     [(f/widget
       (m/Visibility
        .visible (or restructure-mode? false)
        .child
        (m/IconButton
         .onPressed
         (fn []
           (popup/delete-section
            ctx
            note-id
            section-id
            section
            *section-size))
         .icon (m/Icon m/Icons.delete))))
      (m/Spacer)]

     (section-header-siblings  section   premium? note-id restructure-mode? *section-size)))))

(defn show-sections [note-id tutorial? text-search sorted-sections section-list-controller]
  (ss/SuperSliverList
   .listController section-list-controller
   .delegate
   (let [all-sections
         (into []
               (keep
                (fn [[section-id section]]
                  (let [type (section "type")
                        section-name- (section "name")]
                    (when (or (string/blank? text-search)
                              (string/includes? (string/lower-case (str section))
                                                text-search))
                      (f/widget
                       :watch [recently-added-section (rd/subscribe [::model/recently-added-section])
                               section-size (atom
                                             (if (= recently-added-section section-id) 0 100)) :as *section-size
                               restructure-mode (rd/subscribe [::model/get-restructure-mode section-id])]

                       :managed [_ (m/WidgetsBinding.instance.endOfFrame.then
                                    (fn [_]
                                      (reset! *section-size 100)))
                                 :dispose nil]

                       :animate [size section-size
                                 :duration (Duration .milliseconds 200)
                                 :curve m/Curves.easeIn]
                       :managed [section-widget
                                 (show-section section-id restructure-mode  note-id section tutorial? *section-size (section "name") text-search type)
                                 :dispose nil :refresh-on section]

                       m/ClipRect
                       (m/Align
                        .heightFactor (/ size 100))

                       (m/AnimatedCrossFade
                        .crossFadeState (if restructure-mode
                                          m/CrossFadeState.showFirst
                                          m/CrossFadeState.showSecond)
                        .sizeCurve m/Curves.ease
                        .duration (Duration .milliseconds 250)
                        ;;The subwidgets in the section widgets
                        ;;switch based on restructure mode
                        ;;so this works even if it looks weird.
                        .secondChild section-widget
                        .firstChild section-widget)))))
                sorted-sections))]
     (m/SliverChildBuilderDelegate
      (fn [_ i]
        (nth all-sections i))
      .childCount (count all-sections)))))

(defn clone-note-button [plaintext-tc cloning-expanded?]
  (f/widget
   :get [m/ScaffoldMessenger m/Navigator]
   :watch [m (rd/subscribe [::model/current-note])
           premium? (rd/subscribe [::model/premium?])
           notes (rd/subscribe [::model/get-notes])
           prefs (rd/subscribe [::model/prefs])
           brightness (rd/subscribe [::model/get-brightness])
           enable-clone-highlight? (rd/subscribe [::model/enable-clone-highlight])]
   :get {{cs .-colorScheme} m/Theme}
   :context ctx
   :get {{tthm .-textTheme} m/Theme}

   :managed [controller (m/OverlayPortalController) :dispose nil]

   :bg-watcher ([enable-clone-highlight? (rd/subscribe [::model/enable-clone-highlight])]
                (println "enable clone highlight " enable-clone-highlight?)
                (if enable-clone-highlight?
                  (.show controller)
                  (.hide controller)))
   (m/TextButton
    .onPressed
    (fn []
      (clone-button-onpressed navigator m scaffold-messenger premium? ctx)
      nil)

    .child
    (m/OverlayPortal
     .controller controller
     .overlayChildBuilder
     (fn [_]
       (m/Positioned
        .top 100
        .child
        (m/Card
         .elevation 4.0
         .child
         (model/outline
          (f/widget
           :padding {:vertical 12
                     :horizontal 12}
           :get [m/MediaQuery]
           (m/SizedBox
            .width (- (.-width (.-size media-query))
                      100))

           m/Column
           .children
           (concat
            [(m/Text
              "Clone for reuse"
              .style (.-titleLarge tthm))
             (m/SizedBox .height 12)
             (m/Align
              .alignment m/Alignment.bottomLeft
              .child (m/Text "Clone to create a similar note."
                             .style (.-bodyLarge tthm)))
             (m/Align
              .alignment m/Alignment.bottomRight
              .child (m/TextButton
                      .onPressed (fn []
                                   (rd/dispatch [::model/set-key :enable-clone-highlight nil]))
                      .child (m/Text "Hide")))]))
          0.1 2 20))))
     .child
     (if enable-clone-highlight?
       (model/outline
        (f/widget
         :padding {:horizontal 4
                   :vertical 4}
         (m/Icon m/Icons.copy_all .color (.-onSurfaceVariant cs)
                 .size 24))
        1 2 40)

       (m/Icon m/Icons.copy_all .color (.-onSurfaceVariant cs)
               .size 24))))))

(defn in-note-search [*text-search]
  (f/widget
   :managed [tc (m/TextEditingController)]
   :get {{cs .-colorScheme} m/Theme}

   :get [:*expanded-searchbar]
   (m/AnimatedSwitcher
    .duration (Duration .milliseconds 300)
    .child (if @*expanded-searchbar
             (m/SearchBar
              .controller tc
              .elevation (m/MaterialStateProperty.all 0.0)
              .autoFocus true
              .hintText "Find in sections"
              .leading (m/IconButton
                        .icon (m/Icon m/Icons.arrow_left)
                        .onPressed
                        (fn []
                          (.-text! tc "")
                          (reset! *text-search "")
                          (swap! *expanded-searchbar not)))

              .trailing [(m/IconButton
                          .onPressed
                          (fn []
                            (.-text! tc "")
                            (reset! *text-search "")
                            nil)
                          .icon (m/Icon m/Icons.clear))]

              .constraints (m/BoxConstraints
                            .maxWidth 350)

              .onChanged (fn [text]
                           (reset! *text-search text)
                           (when (= "" text)
                             (swap! *expanded-searchbar not))))
             (m/IconButton
              .icon (m/Icon m/Icons.search
                            .color (.-onSurfaceVariant cs))
              .onPressed (fn []
                           (swap! *expanded-searchbar not)))))))

(defn appbar-add-section [note premium? section-list-controller scroll-controller]
  (f/widget
   :managed [gk (m/GlobalKey) :dispose nil]
   :let [allow? (or premium? (<= (count (:sections note)) 1))]
   :get [m/ScaffoldMessenger]
   :context ctx
   (m/PopupMenuButton
    .tooltip "Add section"
    .key gk
    .child
    (m/IconButton
             .icon (m/Icon (if allow?
                             m/Icons.post_add
                             m/Icons.star_outline))

             .onPressed (fn []
                          (if allow?
                            (.showButtonMenu (.-currentState gk))
                            (model/prompt-to-paywall scaffold-messenger "More than two sections requires premium"))))
    .itemBuilder add-section-itembuilder

    .onSelected (fn [selected]
                  
                  (model/unfocus-then-run
                   (rd/dispatch [::model/reset-restructure-mode])
                   (cond
                                        ; (and premium? (= "ai-gen" selected)) (magic ctx)
                                        ; (= "ai-gen" selected) (model/paywall scaffold-messenger)
                     (= "ai-gen" selected) (magic ctx)
                     :else (add-section selected ctx section-list-controller scroll-controller)))))))

(defn appbar [plaintext-tc  *text-search cloning-expanded? first-launch? old-note? ]
  (m/AppBar
   .leading
   (f/widget
    :context ctx
    :get [:*expanded-searchbar]
    :get [m/Navigator m/ScaffoldMessenger]
    :watch [notes (rd/subscribe [::model/get-notes])
            note (rd/subscribe [::model/current-note])
            enable-clone-highlight? (rd/subscribe [::model/enable-clone-highlight])]
    :get {{cs .-colorScheme} m/Theme}
    (m/Visibility
     .visible (not @*expanded-searchbar))
    (m/Tooltip
     
     .message "Go back (notes are autosaved)")
    (m/IconButton
     .icon
     (if (and
          (nil? enable-clone-highlight?)
          first-launch?
          (every? :tutorial notes)
          (seq (:tags note))
          (seq (:sections note)))
       (model/outline (m/Icon m/Icons.arrow_back
                              .color (.-onSurfaceVariant cs))
                      0.5 2 10)
       (m/Icon m/Icons.arrow_back
               .color (.-onSurfaceVariant cs)))
     .onPressed
     (fn []
       (.pop navigator)
       (model/exit-edit-note scaffold-messenger old-note?))))

   .title
   (m/Tooltip
    .message "Clone to re-use sections"
    .child (clone-note-button plaintext-tc cloning-expanded?))

   .actions
   [(f/widget
     :watch [note (rd/subscribe [::model/current-note])
             premium? (rd/subscribe [::model/premium?])]
     :get [:section-list-controller :scroll-controller :*expanded-searchbar]
     (m/Visibility
      .visible (not @*expanded-searchbar)
      .child (appbar-add-section note premium? section-list-controller scroll-controller)))
    
    (f/widget
     :watch [sections (rd/subscribe [::model/current-sections])]
     (m/Tooltip
      .message "Search in sections")
     (m/Visibility
      .visible (<= 1 (count sections)))

     (in-note-search *text-search))

    (table-of-content)

    (m/Flexible
     .child
     (f/widget
      :padding {:right 12}
      :get [:*expanded-searchbar]
      (m/Visibility
       .visible (not @*expanded-searchbar))
      (popup/properties-menu)))]))

(defn edit [current-id {:keys [jumpto autofocus? first-launch? old-note?]}]
  (f/widget
   :managed [plaintext-tc (MarkdownTextEditingController)
             title-tc (m/TextEditingController)
             section-list-controller (ss/ListController)
             scroll-controller (m/ScrollController)
             section-menu-globalkey (m/GlobalKey) :dispose nil]

   :watch [text-search (atom "") :as *text-search]
   :watch [expanded-searchbar? (atom false) :as *expanded-searchbar
           premium? (rd/subscribe [::model/premium?])
           ai-generating? (rd/subscribe [::model/ai-generating?])
           cloning-expanded? (atom false) :as *cloning-expanded?]
   :bind {:*text-search *text-search
          :text-search text-search
          :first-launch? first-launch?
          :*expanded-searchbar *expanded-searchbar
          :section-list-controller section-list-controller
          :scroll-controller scroll-controller}
   :context ctx
   :get [m/Navigator m/ScaffoldMessenger]
   :get {{cs .-colorScheme} m/Theme}
   ;; (m/GridPaper
   ;;  .color m/Colors.red
   ;;  .interval 100
   ;;  .divisions 1)
   (m/CallbackShortcuts
    .bindings (bindings ctx section-menu-globalkey section-list-controller scroll-controller))
   (m/Focus
    .autofocus true)
   (m/PopScope
    .canPop true
    .onPopInvokedWithResult
    (fn [_ _]
      (when first-launch?
        (await (tutorial/schedule-habit-reminders))

        (when (= "true" (model/remote-conf "onboarding_show_note_selector"))
          (-> ctx go_router/GoRouterHelper
              (.goNamed "note-selector"))))

      (model/exit-edit-note scaffold-messenger old-note?)))

   (m/Scaffold
    .appBar (appbar plaintext-tc  *text-search cloning-expanded? first-launch? old-note?)
    .body

    (m/SafeArea
     .child
     (f/widget
      :context ctx
      :watch [password (rd/subscribe [::model/password])]
      :get [m/ModalRoute]
      :bg-watcher ([snapshot (try (when-let [id (or current-id
                                                    (:id old-note?))]
                                    (.snapshots
                                     (.doc
                                      (.collection FirebaseFirestore.instance "notes2")
                                      id)))
                                  (catch Exception e nil))]
                   (when snapshot
                     (let [note (into {} (for [[k v]
                                               (model/firestore-stream->map snapshot)]
                                           [(keyword k) v]))]
                       
                       (when (and (:plaintext note)
                                  (.-isCurrent modal-route))
                         (if (:encrypted note)
                           (when-let [note (await (decrypt-note ctx note password navigator))]
                             (rd/dispatch [::model/set-current-note-local note]))

                           (rd/dispatch [::model/set-current-note-local note])))

                       (when (string/blank? (.-text plaintext-tc))
                         (.-text! plaintext-tc (or (:plaintext note) ""))))))

      :watch [note (rd/subscribe [::model/current-note])]

      :managed [focus (m/FocusNode)
                title-focus (m/FocusNode)
                _ (do (m/WidgetsBinding.instance.addPostFrameCallback
                       (fn [_]
                         (when jumpto
                           (.jumpToItem section-list-controller
                                        .scrollController scroll-controller
                                        .index jumpto
                                        .alignment 1.0))

                         (when (not= (.-text plaintext-tc) (str (:plaintext note)))
                           (.-text! plaintext-tc (str (:plaintext note))))

                         (when (not= (.-text title-tc) (str (:title note)))
                           (.-text! title-tc (str (:title note))))

                         nil))
                      nil) :dispose nil]

      :get [m/ScaffoldMessenger]
      :context ctx
      :get {{tthm .-textTheme} m/Theme}

      :bg-watcher ([autofocus? (rd/subscribe [::model/focus-plaintext?])]
                   (when autofocus?
                     (.requestFocus title-focus)
                     (rd/dispatch [::model/set-key :focus-plaintext? nil])))

      :get [m/Navigator]
      :watch [sorted-sections (rd/subscribe [::model/current-sorted-sections])
              notes (rd/subscribe [::model/get-notes])]

      ;;Watch out, this won't be cleared when switching notes
      ;;but for the use of it that's ok. Just be careful when relying on it for future functionality.

      :watch [prefs (rd/subscribe [::model/prefs])]

      :watch [hide-vid-tutorial? (atom (or (prefs "tutorial_edit") false)) :as *svt?
              section-expanded?
              (atom false) :as *section-expanded?]

      ;;Sometimse the previously visited note is still loaded before the current note has been synced, so don't show the old note.
      (if (or (not= (:id note) current-id)
              (nil? note))
        (f/widget
         :padding {:horizontal 20}
         m/Center
         (m/Container
          .width 400
          .child (m/LinearProgressIndicator)))

        (f/widget
         :watch [reorder-sections? (rd/subscribe [::model/reorder-sections?])]
         :padding {:horizontal 4}
         :managed [highlight-title-and-body?
                   (and (every? :tutorial notes)
                        (string/blank? (:title note))
                        (string/blank? (:plaintext note)))
                   :dispose nil :refresh-on note]

         (m/AnimatedSwitcher
          .duration (Duration .milliseconds 300)
          .child
          (if reorder-sections?
            (reorder-sections-mode)

            (m/CustomScrollView
             .controller scroll-controller
             .slivers

             [(m/SliverToBoxAdapter
               .child
               (f/widget
                :padding {:top 4}
                (let [section
                      (m/Card
                       .elevation 0.0
                       .child
                       (f/widget
                        :padding {:vertical 4}
                        (m/Column
                         .children
                         [(title-widget focus title-tc title-focus highlight-title-and-body?)
                          (body-widget plaintext-tc focus highlight-title-and-body?)])))]

                  section)))

              (clone-icon tthm note)

              (links tthm)
              (show-sections (:id note)
                             false
                             text-search
                             sorted-sections
                             section-list-controller)

              (m/SliverFillRemaining
               .hasScrollBody false
               .child
               (f/widget
                :padding {:left 0}
                (m/Column
                 .mainAxisAlignment m/MainAxisAlignment.end
                 .children
                 (concat
                  (when ai-generating?
                    [(f/widget
                      :padding {:top 20}
                      (m/Container
                       .width 400
                       .child  (m/LinearProgressIndicator)))])
                  [(add-section-button note
                                       section-menu-globalkey
                                       section-list-controller
                                       scroll-controller)
                   (tags note)
                   (m/Row
                    .mainAxisAlignment m/MainAxisAlignment.spaceBetween

                    .children
                    (concat [(last-updated-widget note)]
                            (when kIsWeb
                              [(f/widget
                                :get {{tthm .-textTheme} m/Theme}
                                :watch [brightness (rd/subscribe [::model/get-brightness])]

                                (m/Text "Keyboard shortcuts: alt+f1. Press tab if not responding."
                                        .style (.merge
                                                (.-bodySmall tthm)
                                                (theme/faded-text-style brightness))))])))]))))]))))))))))
