(defn decrypt-note [ctx note password navigator]
  (if (nil? password)
    (let [pw (await (m/showDialog
                     .context ctx
                     .builder
                     (f/build
                      :get [m/Navigator]
                      :managed [tc (m/TextEditingController)]
                      :get {{tthm .-textTheme} m/Theme}

                      (m/AlertDialog
                       .content
                       (m/Column
                        .mainAxisSize m/MainAxisSize.min
                        .children
                        [(m/Text "Insert password to decrypt note"
                                 .style (.-titleLarge tthm))
                         (m/TextField
                          .obscureText true
                          .controller tc)])

                       .actions [(m/TextButton
                                  .onPressed #(.pop navigator)
                                  .child (m/Text "Cancel"))

                                 (m/TextButton
                                  .onPressed (fn []
                                               (rd/dispatch
                                                [::model/set-key :password (.-text tc)])
                                               (.pop navigator (.-text tc)))
                                  .child (m/Text "Ok"))]))))]
      (if pw (await (model/decrypt-note note pw)) (.pop navigator)))

    (await (model/decrypt-note note password))))

