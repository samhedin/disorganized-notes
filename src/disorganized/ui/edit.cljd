(def ^#/(List m/PopupMenuEntry) add-section-itembuilder (fn [_]
                                                          #dart ^m/PopupMenuEntry
                                                          [(m/PopupMenuItem
                                                            .value "ai-gen"
                                                            .child (m/ListTile
                                                                    .title (m/Text "AI generate section")
                                                                    .leading (m/Icon m/Icons.auto_awesome)))

                                                           (m/PopupMenuItem
                                                            .value "list"
                                                            .child
                                                            list-tile)

                                                           (m/PopupMenuItem
                                                            .value "table2"
                                                            .child table-tile)

                                                           (m/PopupMenuItem
                                                            .value "text"
                                                            .child (m/ListTile
                                                                    .title (m/Text "Text")
                                                                    .leading (m/Icon m/Icons.text_fields)))

                                                           (m/PopupMenuItem
                                                            .value "reminder"
                                                            .child reminder-tile)

                                                           (m/PopupMenuItem
                                                            .value "media2"
                                                            .child media-tile)

                                                           (m/PopupMenuItem
                                                            .value "voice"
                                                            .child voice-tile)

                                                           (m/PopupMenuItem
                                                            .value "timer"
                                                            .child timer-tile)

                                                           (m/PopupMenuItem
                                                            .value "alarm"
                                                            .child alarm-tile)

                                                           (m/PopupMenuItem
                                                            .value "location"
                                                            .child (m/ListTile
                                                                    .title (m/Text "Location")
                                                                    .leading (m/Icon m/Icons.gps_fixed)))

                                                           (m/PopupMenuItem
                                                            .value "mindmap"
                                                            .child (m/ListTile
                                                                    .title (m/Text "Mindmap (beta)")
                                                                    .leading (m/Icon m/Icons.hub)))]))
(defn add-section-button [note section-menu-globalkey section-list-controller scroll-controller]
  (f/widget
   :watch [premium? (rd/subscribe [::model/premium?])
           saved-notes (rd/subscribe [::model/get-notes])
           onboarding-section (rd/subscribe [::model/onboarding-section])]

   :managed [overlaycontroller (m/OverlayPortalController) :dispose nil
             tutorial? (and (every? :tutorial saved-notes)
                            (empty? (note :sections))

                            ;;Include these if the user should input text first.
                            ;; (or (not (string/blank? (:plaintext note)))
                            ;;     (not (string/blank? (:title note))))
                            )
             :dispose nil :refresh-on [note]]
   :get [m/ScaffoldMessenger]
   :get {{tthm .-textTheme} m/Theme}
   :let [allow? (or premium? (<= (count (:sections note)) 1))]
   :context ctx

   :get {{cs .-colorScheme} m/Theme}
   :padding {:top 24
             :bottom (if kIsWeb 4 0)}
   (m/Align
    .alignment m/Alignment.bottomLeft)
   (let [popupmenu (m/PopupMenuButton
                    .constraints (m/BoxConstraints
                                  .maxHeight (if tutorial? 400 500))
                    .clipBehavior m/Clip.antiAlias
                    .key section-menu-globalkey
                    .child
                    (m/SizedBox
                     .width 145
                     .child (m/ElevatedButton.icon
                             .icon (m/Icon (if allow?
                                             m/Icons.post_add
                                             m/Icons.star_outline))

                             .label (m/OverlayPortal
                                     .controller overlaycontroller
                                     .overlayChildBuilder
                                     (fn [_]
                                       (m/Positioned
                                        .bottom 470
                                        .child
                                        (m/Card
                                         .elevation 4.0
                                         .child
                                         (model/outline
                                          (f/widget
                                           :padding {:vertical 12
                                                     :horizontal 12}
                                           :get [m/MediaQuery]
                                           (m/SizedBox
                                            .width (- (.-width (.-size media-query))
                                                      100))

                                           m/Column
                                           .children
                                           (concat
                                            [(m/Align
                                              .alignment m/Alignment.bottomLeft
                                              .child (m/Text (if onboarding-section
                                                               "Add your section!"
                                                               "Build your notes with sections, select one to try!")
                                                             .style (.-bodyLarge tthm)))]))
                                          0.1 2 20))))
                                     .child (m/Text "Sections"))
                             .onPressed (fn []
                                          (when tutorial?
                                            (utils/log-analytics "onboarding_sections_displayed" {})
                                            (.show overlaycontroller))

                                          (if allow?
                                            (.showButtonMenu (.-currentState section-menu-globalkey))
                                            (model/prompt-to-paywall scaffold-messenger "More than two sections requires premium")))))
                    .itemBuilder add-section-itembuilder
                    .onCanceled (fn []
                                  (.hide overlaycontroller))

                    .onSelected (fn [selected]
                                  (.hide overlaycontroller)
                                  (when onboarding-section
                                    (utils/log-analytics "onboarding_section_selected" {"section" selected})
                                    (rd/dispatch [::model/set-key :onboarding-section nil]))

                                  (model/unfocus-then-run
                                   (rd/dispatch [::model/reset-restructure-mode])
                                   (cond
                                        ; (and premium? (= "ai-gen" selected)) (magic ctx)
                                        ; (= "ai-gen" selected) (model/paywall scaffold-messenger)
                                     (= "ai-gen" selected) (magic ctx)
                                     :else (add-section selected ctx section-list-controller scroll-controller)))))]
     (if tutorial?
       (model/outline popupmenu 0.8 5 20)
       popupmenu))))

(defn appbar-icon [child]
  (f/widget
   :get [:*expanded-searchbar]
   (m/Visibility
    .visible (not @*expanded-searchbar))
   (m/Flexible
    .child
    child)))

(defn table-of-content []
  (f/widget
   :watch [sections (rd/subscribe [::model/current-sections])]
   :get [:*expanded-searchbar
         :section-list-controller
         :scroll-controller]

   :get {{cs .-colorScheme} m/Theme}
   (m/Visibility
    .visible (and (< 1 (count sections))
                  (not @*expanded-searchbar))
    .child
    (m/PopupMenuButton
     .tooltip "Jump to section"
     .icon (m/Icon m/Icons.toc
                   .color (.-onSurfaceVariant cs))
     .itemBuilder
     (fn [_]
       (let [^#/(List m/PopupMenuItem) s
             (mapv
              (fn [[id {:strs [name type]}]]
                (let [presented-type  (string/capitalize
                                       (str (case type
                                              "table2" "table"
                                              "media2" "media"
                                              type)))]
                  (m/PopupMenuItem
                   .value id
                   .child (m/Text
                           (if (or (= name type)
                                   ;;If the name is e.g "list1" 
                                   (= (subs name 0 (dec (count name)))
                                      presented-type))
                             name
                             (str name ": " presented-type))))))

              (sort-by (fn [[_ {:strs [section-position]}]]
                         section-position)
                       sections))]
         s))
     .onSelected (fn [s]

                   (let [section (second (first (filter (fn [[section-id _]]
                                                          (= s section-id)) sections)))

                         index (section "section-position")]
                     (println "jumping to " index)
                     (.jumpToItem
                      section-list-controller
                      .scrollController scroll-controller
                      .index index
                      .alignment 0.0)))))))

(defn tag-at-pos [text pos]
  (when (and (>= pos 0) (<= pos (count text)))
    (let [;; Find the start of the current word
          word-start (loop [i (dec pos)]
                       (cond
                         (< i 0) 0
                         (re-matches #"[a-zA-Z0-9#_-]" (str (get text i))) (recur (dec i))
                         :else (inc i)))
          ;; Find the end of the current word
          word-end (loop [i pos]
                     (cond
                       (>= i (count text)) (count text)
                       (re-matches #"[a-zA-Z0-9#_-]" (str (get text i))) (recur (inc i))
                       :else i))
          ;; Extract the current word
          current-word (subs text word-start word-end)]
      ;; Only return if it's a valid tag - using the same pattern as the regex function
      (when (re-matches #"#[a-zA-Z0-9_-]+" current-word)
        {:tag current-word
         :tag-start word-start
         :tag-end word-end}))))

(defn ensure-unique-name [note name count]
  (let [name (case name
               "table2" "table"
               "media2" "media"
               name)]
    (if (contains? (:sections note) name)
      (str name count)
      name)))

(defn rename-section
  [section-id section-name ^m/TextEditingController tc]
  (println "renaming to " (.-text tc))
  (let [newn (.-text tc)]
    (if (string/blank? newn)
      (.-text! tc section-name)
      (rd/dispatch [::model/update-current-note
                    (fn [m]
                      (assoc-in m [:sections section-id "name"] newn))])))
  nil)

