(defn settings-button [child onpressed]
  (m/ElevatedButton
   .child child
   .onPressed onpressed))

(defn radio-list-tile [title value groupValue onChanged]
  (f/widget
   :padding {:vertical 5}
   (if (= value groupValue)
     (m/Card
      .elevation 0.5
      .child (m/RadioListTile
              .title title
              .value value
              .groupValue  groupValue
              .onChanged
              onChanged))

     (m/RadioListTile
      .title title
      .value value
      .groupValue  groupValue
      .onChanged
      onChanged))))

(defn android-widget-update-preference [key value *property]
  (rd/dispatch [::model/update-user-options
                {key value}])

  (let [prefs (await (sp/SharedPreferences.getInstance))]
    (await (.setString prefs key value)))
  (await (HomeWidget.updateWidget
          .androidName "NoteWidgetReceiver"))
  (reset! *property value)
  (rd/dispatch [::model/fetch-user-options]))

(defn android-widget-background-color [android-widget-bg-color- *android-widget-bg-color]
  [(radio-list-tile
    (m/Text "Black")
    "black"
    android-widget-bg-color-

    (fn [v]
      (android-widget-update-preference "widget-color" v *android-widget-bg-color)))

   (radio-list-tile

    (m/Text "White")
    "white"
    android-widget-bg-color-

    (fn [v]
      (android-widget-update-preference "widget-color" v *android-widget-bg-color)))

   (radio-list-tile

    (m/Text "Transparent")
    "transparent"
    @*android-widget-bg-color

    (fn [v]
      (android-widget-update-preference "widget-color" v *android-widget-bg-color)))])

(defn android-widget-text-size [*android-widget-text-size]
