(defn properties-menu []
  (f/widget
   :context ctx
   :watch [view-archive (rd/subscribe [::model/watch-view-archive])
           note-sorting (rd/subscribe [::model/watch-note-sorting])]
   :watch [brightness (rd/subscribe [::model/get-brightness])]

   :watch [prefs (rd/subscribe [::model/prefs])
           saved-notes (rd/subscribe [::model/get-notes])]

   :managed [has-read-news? (or
                             (< (count saved-notes) 5)
                             (and
                              (some? (prefs "last_read_news"))
                              (.isAfter
                               (.toDate (prefs "last_read_news"))
                               (DateTime.utc 2026 03 12)))) :dispose nil]
   :padding {:right 4}
   :get {{cs .-colorScheme} m/Theme}

   (m/PopupMenuButton
    .clipBehavior m/Clip.antiAlias
    .tooltip "Settings"
    .child (if has-read-news?
             (m/Icon m/Icons.more_vert)
             (model/outline (m/Icon m/Icons.more_vert)))
    .itemBuilder (fn [_]
                   #dart ^m/PopupMenuEntry
                    [(m/PopupMenuItem
                      .value "settings"
                      .child (m/ListTile
                              .title (m/Text "Settings")))

                     (m/PopupMenuItem
                      .value "archive"
                      .child (m/ListTile
                              .title (m/Text (if view-archive
                                               "Hide archive"
                                               "View archive"))))

                     (m/PopupMenuItem
                      .value "refresh"
                      .child (m/ListTile
                              .title (m/Text "Reload notes")))

                     (m/PopupMenuItem
                      .value "news"
                      .child (if has-read-news?
                               (m/ListTile
                                .title (m/Text "News"))

                               (model/outline
                                (f/widget
                                 :padding {:left 12}
                                 (m/ListTile
                                  .title  (m/Text "News"))))))

;; (m/PopupMenuItem
                    ;;  .value "encrypted"
                    ;;  .child (m/Text "Create encrypted note"))

                    ;; (m/PopupMenuItem
                    ;;  .value "sortby"
                    ;;  .child (m/Text
                    ;;          (if note-sorting
                    ;;            "Sort by Date created"
                    ;;            "Sort by Date modified")))
                     ])
    .onSelected (fn [selection]
                  (case selection
                    "sortby" (rd/dispatch [::model/set-key
                                           :note-sorting
                                           (if note-sorting
                                             nil
                                             :created_at)])
                    "news" (do
                             (rd/dispatch [::model/update-user-options
                                           {"last_read_news" (DateTime.now)}])
                             (show-news ctx))
                    "refresh" (rd/dispatch [::model/refresh-notes])
                    "archive" (rd/dispatch [::model/set-key
                                            :view-archive
                                            (not view-archive)])
                    "settings" (-> ctx go_router/GoRouterHelper
                                   (.push
                                    "/settings")))
                  nil))))

(def expanded-searchbar-animation-duration 170)
(defn appbar
  "Not actually an appbar since that ruins the edit view, since it's on the same page now."
  [selected-tags expanded-searchbar? *expanded-searchbar *notes
   saved-notes *selected-tags]
  (f/widget
   :watch [premium? (rd/subscribe [::model/premium?])]
   :get {{cs .-colorScheme} m/Theme}
   :watch [prefs (rd/subscribe [::model/prefs])]

   :context ctx
   (m/Row
    .children
    (concat
     [(m/Expanded
       .child
       (f/widget
        :managed [search-focus (m/FocusNode)]
        :watch [saved-notes-strings (atom nil) :as *saved-notes-strings]
        :watch [saved-notes (rd/subscribe [::model/get-notes])
                id->saved-notes-index (rd/subscribe [::model/id->saved-notes-index])]
                                        ;        :key "animated-seachbar"
        (m/AnimatedCrossFade
         .duration (Duration .milliseconds expanded-searchbar-animation-duration)

         .crossFadeState (if expanded-searchbar?
                           m/CrossFadeState.showFirst
                           m/CrossFadeState.showSecond)
         .firstChild (f/widget
                      :padding {:left 8}
                      (m/Align
                       .alignment m/Alignment.bottomLeft)

                      (m/Row
                       .mainAxisAlignment m/MainAxisAlignment.start
                       .children
                       [(m/Flexible
                         .child (m/Tooltip
                                 .message "Search in notes, both text and sections."
                                 .child (m/IconButton
                                         .color (.-onSurfaceVariant cs)
                                         .icon (m/Icon m/Icons.search)
                                         .onPressed (fn []
                                                      (swap! *expanded-searchbar not)
                                                      (reset! *saved-notes-strings
                                                              (searchable-notes saved-notes))
                                                      ;;Let the animation play before focus
                                                      (Future/delayed
                                                       (Duration
                                                        .milliseconds
                                                        (+ 5 expanded-searchbar-animation-duration))
                                                       (fn []
                                                         (.requestFocus search-focus)))
                                                      nil))))
                        (m/Tooltip
                         .message
                         "Only show notes with section..."
                         .child (section-filtering-menu))]))
         .secondChild (expanded-searchbar *notes saved-notes *expanded-searchbar  id->saved-notes-index selected-tags *selected-tags search-focus saved-notes-strings))))]

     (when  expanded-searchbar?
       (concat
        [(m/IconButton
          .tooltip "Reminders"
          .icon (m/Icon m/Icons.notifications_outlined)
          .onPressed (fn []
                       (-> ctx go_router/GoRouterHelper
                           (.push
                            "/reminders"))
                       nil))]

        (when kIsWeb
          [(m/Tooltip
            .message "Refresh all notes"
            .child
            (m/IconButton
             .onPressed (fn []
                          (rd/dispatch [::model/refresh-notes])
                          nil)
             .icon (m/Icon m/Icons.refresh)))])
        [(m/Flexible
          .flex 0
          .child (properties-menu))]))))))

(defn click-me-button
  "I often want to trigger some logic easily and that can be done here."
  []
  (f/widget
   :context ctx
   :watch [notes (rd/subscribe [::model/get-notes])]
   (m/OutlinedButton
    .onPressed
    (fn []
      
       (mapv model/valid-note? notes)
      )

    .child (m/Text (str "Click me")))))

(defn tag-chips [selected-tags *selected-tags]
  (m/SliverToBoxAdapter
   .child
   (f/widget
    :watch [review-available? (.isAvailable (.instance review/InAppReview))
            note-id-to-open? (rd/subscribe [::model/watch-note-to-open])
            saved-notes (rd/subscribe [::model/get-notes])
            premium? (rd/subscribe [::model/premium?])]

    :bg-watcher ([user-stream (when-let [uid  (model/uid)]
                                (.snapshots
                                 (.doc
                                  (.collection FirebaseFirestore.instance "users")
                                  uid)))]

                 (let [pinned-tags (when-let [parsed (model/firestore-stream->map user-stream)]
                                     (parsed "pinned-tags"))]

                   (when (seq pinned-tags)
                     (rd/dispatch [::model/set-key :pinned-tags pinned-tags]))))

    :watch [{:keys [all-tags intersecting-tags]} (rd/subscribe [::model/all-tags-sub])]
    :get {{tthm .-textTheme} m/Theme}
    :context ctx
    :managed [_ (do (m/WidgetsBinding.instance.addPostFrameCallback
                     (fn [_]
                       (when (and (not premium?) kIsWeb (not kDebugMode))
                         (web-premium-popup ctx))

                       (when (< 8 (count saved-notes))
                         (when (and review-available?
                                    (not kDebugMode)
                                    (not kIsWeb))
                           (.requestReview
                            (.instance review/InAppReview))
                           nil))

                       (let [at (into #{} all-tags)]

                         ;;If the user has an e.g recipe tag and deletes all recipe notes,
                         ;;the recipe tag will be removed from the UI but won't be
                         ;;removed from the filters unless we do this.
                         ;;So this has to be done otherwise the user can't deselect the tag.
                         (when (seq (clojure.set/difference selected-tags at))
                           (reset! *selected-tags #{})))

                       (when note-id-to-open?
                         (rd/dispatch [::model/set-current-note-id note-id-to-open?]))))
                    nil) :dispose nil]

    (m/AnimatedSwitcher
     .duration (Duration .milliseconds 200)
     .child
     (f/widget
      :key (count selected-tags)
      (m/Align
       .alignment m/Alignment.bottomLeft)

      (f/widget
       :padding {:left 4}
       :managed [children (concat
                           (when (seq selected-tags)
                             [(m/IconButton
                               .icon (m/Icon m/Icons.clear)
                               .onPressed (fn []
                                            (reset! *selected-tags #{})))])
                           (keep (fn [t]
                                   ;;to show a tag:
                                   (when (or
                                          (empty? selected-tags)

                                          ;;ALL TAGS in selected-tags MUST have t as an intersecting-tag
                                          (every? (fn [selected-tag]
                                                    (let [intersecting
                                                        ;;intersecting tags is a map that takes a tag and returns all tags that it is in a note with
                                                          (intersecting-tags selected-tag)]
                                                      (intersecting t)))
                                                  selected-tags))
                                     (filterchip t selected-tags *selected-tags tthm)))
                                 all-tags))
                 :refresh-on [selected-tags all-tags]
                 :dispose nil]

       (m/SizedBox
        .height (if (seq children) 48 0)
        .child (m/ListView.builder
                .scrollDirection m/Axis.horizontal
                .shrinkWrap true
                .itemCount (count children)
                .itemBuilder (fn [_ i]
                               (nth children i))))))))))

(defn shared-note [m]
  (let [emails (map (fn [[_ email]] email) (:user_emails m))]
    (f/widget
     :context ctx
     :get [m/Navigator]
     .child
     (m/ElevatedButton.icon
      .onPressed (fn []
                   (popup/show-collaborators (apply str emails) ctx)
                   nil)
      .icon (m/Icon m/Icons.group)
      .label (m/Text "Shared")))))

(defn- clone-button-onpressed [saved-notes ctx  ^m/ScaffoldMessengerState scaffold-messenger m  premium?]
  (fn []
    (let [new-note (await (utils/clone-note m scaffold-messenger premium?))]
      (when new-note
        (rd/dispatch [::model/upload-note  [new-note true]])
        (rd/dispatch
         [::model/set-current-note-id (:id new-note)])

        (-> ctx go_router/GoRouterHelper
            (.pushNamed  "edit"
                         .pathParameters {"id" (:id new-note)}
                         .extra {:autofocus false}))
        (rd/dispatch [::model/set-new-plaintext ""])
        (rd/dispatch [::model/set-key :override-title ""])
        (.showSnackBar scaffold-messenger
                       (m/SnackBar
                        .persist false
                        .content (m/Text "Copy content from parent?")
                        .action
                        (m/SnackBarAction
                         .label "Yes"
                         .onPressed
                         (fn []
                           (rd/dispatch [::model/update-current-note
                                         (fn [n]
                                           (let [pt (utils/get-new-plaintext (:plaintext m))]

                                             (rd/dispatch [::model/set-new-plaintext pt])
                                             (rd/dispatch [::model/set-key :override-title (:title m)])
                                             (assoc n
                                                    :title (:title m)
                                                    :sections (utils/reset-checkboxes m)
                                                    :plaintext pt)))])))))))
    nil))

(defn cloning-popup [ctx]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    (m/AlertDialog
     .content
     (m/Column
      .mainAxisSize m/MainAxisSize.min

      .children
      [(m/Icon m/Icons.copy_all
               .size 40)
       (m/SizedBox .height 12)
       (m/Center
        .child
        (m/Text "Many notes are similar to each other, for example most recipes contain a table of ingredients.

Use cloning to copy over sections and tags to a new note."))])
     .actions
     [(m/TextButton
       .child (m/Text "Ok")
       .onPressed (fn []
                    (.pop navigator)))]))))

(defn clone-button [ctx m plaintext]
  (f/widget
   :watch [saved-notes (rd/subscribe [::model/get-notes])
           premium? (rd/subscribe [::model/premium?])]
   :get [m/ScaffoldMessenger]
   :get {{cs .-colorScheme} m/Theme}

   (m/Tooltip
    .message "Clone"
    .child (m/IconButton
            .onPressed (clone-button-onpressed saved-notes ctx scaffold-messenger m premium?)
            .onLongPress (fn []
                           (cloning-popup ctx))
            .icon
            (m/Icon m/Icons.copy_all
                    .color (.-onSurfaceVariant cs))))))

(defn start-of-day [now]
  (.subtract now (Duration
                  .hours (.-hour now)
                  .minutes (.-minute now)
                  .seconds (.-second now))))

(defn group-notes-by-period [notes]
  (let [now (DateTime.now)
        today-start (start-of-day now)
        yesterday-start (.subtract today-start (Duration .days 1))
        week-start (.subtract today-start (Duration .days (.weekday now)))
        last-week-start (.subtract week-start (Duration .days 7))
        last-year-start (DateTime (- (.-year now) 1) (+ (.-month now) 1) 1)
        fmt (intl/DateFormat "MMMM")

        groups (group-by (fn [note]
                           (let [updated (:updated_at note)]
                             (cond
                               (.isAfter updated today-start) "Today"
                               (.isAfter updated week-start) "This week"
                               (.isAfter updated last-year-start) (.format fmt updated)
                               :else "Last year"))) notes)

        recent-periods [["Today" (groups "Today")]
                        ["This week" (groups "This week")]]

        month-groups (->> (dissoc groups "Today" "This week" "Last year")
                          (map (fn [[month-key month-notes]]
                                 [month-key month-notes (-> month-notes first :updated_at)]))
                          (sort-by #(nth % 2) (fn [a b] (.isAfter a b)))
                          (map (fn [[month-key month-notes _]] [month-key month-notes])))

        last-year (when (seq (groups "Last year"))
                    [["Last year" (groups "Last year")]])]
    
    (->> (concat recent-periods month-groups last-year)
         (filter (fn [[_ notes]] (seq notes)))
         (into []))))

(defn divider [cs]
  (f/widget
   :color (.-surfaceContainerHigh cs)

   :padding {:vertical 0
             :horizontal 12}
   :color (.-surfaceContainerHigh cs)

   (m/Divider
    .height 0
    .thickness 0.6
    .color (.-onTertiary cs))))

(defn show-note-grid [{:keys [id] :as note}   prefs first? last?]
  (f/widget
   :watch [view-archive (rd/subscribe [::model/watch-view-archive])
           batch-delete-notes (rd/subscribe [::model/batch-delete-notes])]

   :context ctx
   :get {{tthm .-textTheme} m/Theme}
   :watch [brightness (rd/subscribe [::model/get-brightness])]
   :get {{cs .-colorScheme} m/Theme}

   :get [m/ScaffoldMessenger m/Navigator]
   :padding {:horizontal 12}
   :get [:timeformat-24-hours?]
   :managed [radius (m/Radius.circular 17) :dispose nil
             border (m/RoundedRectangleBorder
                     .borderRadius (cond
                                     (and first? last?) (m/BorderRadius.all radius)
                                     first? (m/BorderRadius.only .topLeft radius
                                                                 .topRight radius)

                                     last? (m/BorderRadius.only .bottomLeft radius
                                                                .bottomRight radius)

                                     :else (m/BorderRadius.all (m/Radius.circular 0))))
             :dispose nil]
   (Slidable
    .startActionPane
    (ActionPane
     .motion (fs/DrawerMotion)
     .children
     [(fs/SlidableAction
       .borderRadius theme/border-radius
       .onPressed (fn [_]
                    (ondismiss view-archive note scaffold-messenger))
       .icon m/Icons.archive
       .label "Archive")

      (fs/SlidableAction
       .borderRadius theme/border-radius

       .onPressed (fn [_]
                    (rd/dispatch [::model/save-note
                                  {:note (if (:pin note)
                                           (dissoc note :pin)
                                           (assoc note :pin (DateTime.now)))}]))
       .icon (if (:pin note)
               m/Icons.push_pin
               m/Icons.push_pin_outlined)

       .label (if (:pin note)
                "Unpin"
                "Pin"))])
    .child
    (m/Card
     .shape border
     .margin m/EdgeInsets.zero
     .elevation 0
     .child
     (m/InkWell
      .customBorder border
      .onLongPress (fn []
                     (model/unfocus-then-run
                      (rd/dispatch [::model/set-key :current-note-id nil])

                      (rd/dispatch [::model/add-batch-delete-note id])))

      .onTap
      (fn []
        (if (seq batch-delete-notes)
          (do (if (contains? batch-delete-notes id)
                (rd/dispatch [::model/remove-batch-delete-note id])
                (rd/dispatch [::model/add-batch-delete-note id])))

          (-> ctx go_router/GoRouterHelper
              (.pushNamed "edit"
                          .pathParameters {"id" (:id note)}
                          .extra {:autofocus false})))
        nil)
      .child
      (f/widget
       :padding {:left 16
                 :right 0
                 :top 12
                 :bottom 12}

       (m/Column
        .children
        (concat
         [(m/Row
           .mainAxisAlignment m/MainAxisAlignment.spaceBetween
           .crossAxisAlignment m/CrossAxisAlignment.center
           .children
           (concat
            (when (seq batch-delete-notes)
              [(m/Checkbox
                .value (contains? batch-delete-notes id)
                .onChanged (fn [b]
                             (if b
                               (rd/dispatch [::model/add-batch-delete-note id])
                               (rd/dispatch [::model/remove-batch-delete-note id]))))])

            [(m/Flexible
              .flex 10
              .child
              (f/widget
               (m/Align
                .alignment m/Alignment.bottomLeft)
               (m/ConstrainedBox
                .constraints (m/BoxConstraints
                              .maxHeight 150))

               (m/SingleChildScrollView
                .physics (m/NeverScrollableScrollPhysics))

               (if (:encrypted note)
                 (f/widget
                  :watch [password (rd/subscribe [::model/password])]
                  (m/ListTile
                   .trailing (if password
                               (m/Icon m/Icons.lock_open)
                               (m/Icon m/Icons.lock_outline))
                   .title (m/Text (:title note)
                                  .style (.-titleMedium tthm))))
                 (grid/show-note note))))
             (f/widget
              :watch [user-data-stream (try (.snapshots
                                             (.doc
                                              (.collection FirebaseFirestore.instance "users")
                                              (model/uid)))
                                            (catch Exception e nil))]
              :let [user-data (if user-data-stream
                                (model/dart->clj-ds (.data user-data-stream))
                                {})]

              (m/Column
               .children
               (concat
                [(clone-button ctx note (:plaintext note))]
                (when (< 1 (count (:user_access note)))
                  [(m/IconButton
                    .icon (m/Icon m/Icons.people)
                    .onPressed (fn []
                                 (popup/note-shared
                                  ctx
                                  note
                                  (user-data "friends"))))]))))]))]))))))))

(defn filter-notes [text saved-notes  id->saved-notes-index selected-tags only-with-section scaffold-messenger saved-notes-strings]

  (let [text (string/lower-case (if (= \u200b (first text))
                                  (subs text 1)
                                  text))]
    (if saved-notes-strings ;;This implies that the user is doing a text search
      (keep
       (fn [[id s]]
         (let [note (nth saved-notes (id->saved-notes-index id))
               tags (set (:tags note))
               tag-filtered? (every? tags selected-tags)]
           (when (and tag-filtered?
                      (string/includes? (string/lower-case s) text)
                      (or (nil? only-with-section)
                          (model/note-contains-section?
                           note
                           only-with-section)))
             note)))
       saved-notes-strings)
      (filter
       (fn [note]
         (let [tags (set (:tags note))
               tag-filtered? (every? tags selected-tags)]
           (and tag-filtered?
                (or (nil? only-with-section)
                    (model/note-contains-section? note only-with-section)))))
       saved-notes))))

(defn list-title [text tthm]
  (f/widget
   :watch [brightness (rd/subscribe [::model/get-brightness])]

   :padding {:top 20
             :bottom 12
             :left 16}
   (m/Text text
           .style (.-titleLarge tthm))))

(defn list-notes []
  (f/widget
   :get {{tthm .-textTheme} m/Theme}
   :get [m/Theme]
   :context ctx
   :watch [{verified? .-emailVerified} (.userChanges FirebaseAuth.instance)
           saved-notes (rd/subscribe [::model/get-notes])
           view-archive (rd/subscribe [::model/watch-view-archive])
           premium? (rd/subscribe [::model/premium?])
           note-id-to-open? (rd/subscribe [::model/watch-note-to-open])
           selected-tags (atom #{}) :as *selected-tags]

   :watch [expanded-searchbar? (atom true) :as *expanded-searchbar]
   :managed [search-tc (m/TextEditingController
                        .text (str \u200b))]
   :bind {:search-tc search-tc}

   :get [m/ScaffoldMessenger]
   :watch [{:keys [all-tags]} (rd/subscribe [::model/all-tags-sub])]

   :watch [id->saved-notes-index (rd/subscribe [::model/id->saved-notes-index])
           filter-by-section (rd/subscribe [::model/filter-by-section])

           notes (atom (filter-notes (.-text search-tc)
                                     saved-notes
                                     id->saved-notes-index
                                     selected-tags
                                     filter-by-section
                                     scaffold-messenger
                                     nil)) :as *notes]

   :watch [prefs (rd/subscribe [::model/prefs])

           ;;Leave this here it makes colors update properly
           brightness (rd/subscribe [::model/get-brightness])]

   :watch [hide-vid-tutorial? (atom (or (prefs "video_tutorial") false)) :as *svt?]

   :context ctx
   :get {{cs .-colorScheme} m/Theme}
   :managed [{pinned true
              not-pinned false}
             (group-by #(boolean (:pin %))
                       (filter
                        (fn [n]
                          (if view-archive
                            (n :archived)
                            (not (n :archived)))) notes))
             :dispose nil

             not-pinned-notes
             (flatten
              (map (fn [[date-group notes]]
                     (concat
                      [(list-title date-group tthm)]
                      (flatten (map-indexed
                                (fn [i n]
                                  (concat
                                   [(show-note-grid
                                     n
                                     prefs
                                     (= i 0)
                                     (= i (dec (count notes))))]

                                   (when (not= i (dec (count notes)))
                                     [(divider cs)])))
                                notes))))
                   (group-notes-by-period not-pinned)))
             :dispose nil

             ;;Pinned-notes contains both the actual notes, as well as the
             ;;pinned/unpinned icons.
             pinned-notes (flatten (concat
                                    [(list-title "Pinned" tthm)]
                                    (when (seq pinned)
                                      (map-indexed
                                       (fn [i n]
                                         (concat
                                          [(show-note-grid
                                            n
                                            prefs
                                            (= i 0)
                                            (= i (dec (count pinned))))]
                                          (when (not= i (dec (count pinned)))
                                            [(divider cs)])))
                                       pinned))))
             :dispose nil

             note-list (m/CustomScrollView
                        .physics (m/ClampingScrollPhysics)
                        .slivers
                        [(m/SliverToBoxAdapter
                          .child (appbar selected-tags expanded-searchbar? *expanded-searchbar *notes saved-notes *selected-tags))
                         (archive? view-archive)

                         (tag-chips selected-tags *selected-tags)
                         (scheduled-alarms)
                         (m/SliverVisibility
                          ;;pinned-notes contain 2 items by default, the "pinned" icon and the
                          ;;"unpinned" icon. So if count >= 3 then there is at least one pinned
                          ;;note
                          .visible (>= (count pinned-notes) 2)
                          .sliver (m/SliverList
                                   .delegate
                                   (m/SliverChildBuilderDelegate
                                    (fn [_ index]
                                      (nth pinned-notes index))
                                    .childCount  (count pinned-notes))))

                         ;;Just for development.
                         (m/SliverVisibility
                          .visible (and false kDebugMode)
                          .sliver (m/SliverToBoxAdapter
                                   .child (click-me-button)))

                         (m/SliverList
                          .delegate
                          (m/SliverChildBuilderDelegate
                           (fn [_ index]
                             (nth not-pinned-notes index))
                           .childCount  (count not-pinned-notes)))

                         (get-started saved-notes not-pinned hide-vid-tutorial? *svt? scaffold-messenger verified? ctx prefs tthm)])
             :dispose nil
             :refresh-on
             [notes prefs hide-vid-tutorial? expanded-searchbar? verified? selected-tags saved-notes all-tags brightness not-pinned]]

   ;; (m/GridPaper
   ;;  .color m/Colors.red
   ;;  .interval 100
   ;;  .divisions 1)
   (m/PopScope
    .canPop (boolean (not view-archive))
    .onPopInvokedWithResult (fn [_ _]
                              (when view-archive
                                (rd/dispatch [::model/set-key :view-archive false])))
    .child

    note-list)))
