(defn searchable-notes [notes]
  (mapv
   (fn [{:keys [plaintext title sections] :as note}]
     (let [t (string/lower-case (str title))
           p (string/lower-case (str plaintext))]
       [(:id note) (str  t p (string/lower-case (str sections)))]))
   notes))

(defn make-chapter [title description tthm]
  [(m/Text title .style (.-titleSmall tthm))
   (m/Text description)])

(defn show-news [ctx]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    :get {{tthm .-textTheme} m/Theme}

    (m/AlertDialog
     .content
     (m/Column
      .spacing 8
      .mainAxisSize m/MainAxisSize.min
      .children
      (concat
       [(m/Text "Recent news"
                .style (.-titleLarge tthm))]

       (make-chapter "Improved voice recording" "Voice recordings are now more responsive, faster to process and less buggy. 
Silence is automatically cut out, and transcription quality and list creation is improved.

Try it out!" tthm)
       

       (make-chapter "Mindmap added" "A mindmap section has been added - scroll down to the bottom of the section selector to try it out." tthm)

       (make-chapter "Encryption" "Premium users can now encrypt their notes. 
See note settings for more information - read carefully." tthm)

       [(m/SizedBox .height 24)
        (m/Text "If you have feature requests, bug reports or feedback I'm always available via Discord
-- Sam")]))
     .actions
     [(m/TextButton
       .onPressed (fn []
                    (url/launch "https://discord.gg/UEeughB9Qn")
                    (.pop navigator))
       .child (m/Text "Visit Discord"))
      (m/TextButton
       .onPressed (fn []
                    (.pop navigator))
       .child (m/Text "Ok!"))]))))

(defn web-premium-popup [ctx]
  (m/showDialog
   .barrierDismissible false
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    :get {{tthm .-textTheme} m/Theme}

    (m/AlertDialog
     .content
     (m/Column
      .mainAxisSize m/MainAxisSize.min

      .children
      [(m/Text "Premium required!" .style (.-titleLarge tthm))
       (m/SizedBox .height 4)
       (m/Text "The web app requires premium.

Please purchase premium through the iOS or Android app, then re-open this app and sign in with the same account you used on mobile!")])
     .actions
     [(m/TextButton
       .child (m/Text "Sign out")
       .onPressed (fn []
                    (rd/dispatch [::model/empty-notes])
                    (rd/dispatch [::model/set-user-options {}])
                    (await (.signOut (.-instance FirebaseAuth)))

                    (println "signed out!")))

      (m/TextButton
       .child (m/Text "iOS")
       .onPressed (fn []
                    (url/launch "https://apps.apple.com/us/app/disorganized-notes-todo/id6738280174")
                    nil))

      (m/TextButton
       .child (m/Text "Android")
       .onPressed (fn []
                    (url/launch "https://play.google.com/store/apps/details?id=com.disorganized.disorganized&pli=1&gl=cn")
                    nil))]))))

(defn scheduled-alarms []
  (f/widget
   :watch [{:flds [alarms]} (.scheduled alarm/Alarm)
           prefs (rd/subscribe [::model/prefs])
           brightness (rd/subscribe [::model/get-brightness])]

   :let [color (if (= m/Brightness.dark brightness)
                 (theme/fab-color prefs "dark")
                 (theme/fab-color prefs "light"))]
   :managed [alarm (first
                    (sort-by
                     (fn [alarm]
                       (.-dateTime alarm))
                     alarms))
             :dispose nil :refresh-on alarms]

   :get [m/MediaQuery]
   :get {{cs .-colorScheme} m/Theme}

   (m/SliverVisibility
    .visible (boolean (and alarm (:seconds alarm))))
   .sliver
   (m/SliverToBoxAdapter
    .child (f/widget
            :watch [refresh? (atom nil) :as *refresh?]
            :padding {:bottom 12}
            :context ctx
            :let [{note-id :note-id
                   section-name :section-name
                   minutes :minutes
                   section-position :section-position
                   seconds :seconds
                   hours :hours} (reader/read-string (.-payload alarm))
                  duration (when seconds
                             (Duration .seconds seconds .minutes minutes .hours hours))
                  duration-until-alarm
                  (.difference
                   (.-dateTime alarm)
                   (DateTime.now))

                  progress (. duration "-" duration-until-alarm)]

            :key (str refresh?)
            ;;When the app goes to sleep it stops animating
            ;;And without the refresh, it continues to animate
            ;;from the point when it was put to sleep.
            ;;In other words the timer goes out of sync
            ;;Simply refreshing the widget onResume fixes it.
            :managed [_ (f_widgets/AppLifecycleListener
                         .onResume (fn []
                                     (reset! *refresh? (random-uuid))))]

            (m/Material
             .color m/Colors.transparent
             .shape (m/CircleBorder)
             .clipBehavior m/Clip.antiAlias)
            (m/InkWell
             .customBorder (m/RoundedRectangleBorder
                            .borderRadius theme/border-radius)

             .onTap (fn []
                      (-> ctx go_router/GoRouterHelper
                          (.pushNamed "edit"
                                      .pathParameters {"id" note-id}
                                      .extra {:jumpto section-position
                                              :autofocus false}))
                      nil))

            (ct/CircularCountDownTimer
             .key (m/ValueKey (str progress "countdown"))
             .duration (.-inSeconds duration)
             .strokeWidth 7
             .initialDuration (.-inSeconds progress)
             .width (/ (-> media-query .-size .-width) 10)
             .height (/ (->  media-query .-size .-height) 10)
             .textFormat "HH:mm:ss"
             .fillColor (.-surface cs)

             .textStyle (m/TextStyle
                         .color (if (= m/Brightness.dark brightness)
                                  m/Colors.white
                                  m/Colors.black))
             .ringColor color
             .isReverse true
             .autoStart true)))))

(defn card-theme [lightness]
  (m/RoundedRectangleBorder
   .side (m/BorderSide .color (theme/hsl 0 0 lightness))
   .borderRadius (m/BorderRadius.circular 15)))

(def fab-icon-color m/Colors.white)

(defn add-note-fab-button [prefs tag]
  (f/widget
   :watch [brightness (rd/subscribe [::model/get-brightness])]
   :let [fab-color-light (theme/fab-color prefs "light")
         fab-color-dark (theme/fab-color prefs "dark")]

   :context ctx
   (m/FloatingActionButton
    .heroTag tag
    .backgroundColor (if (= m/Brightness.dark brightness)
                       fab-color-dark
                       fab-color-light)
    .child (m/Icon m/Icons.add
                   .color fab-icon-color)
    .shape (m/CircleBorder)
    .onPressed (fn []
                 (let [note (utils/init-new-note)]
                   (rd/dispatch [::model/upload-note  [note true]])
                   (utils/log-analytics "note_created")
                   (rd/dispatch [::model/set-new-plaintext ""])
                   (rd/dispatch [::model/set-key :override-title ""])
                   (rd/dispatch [::model/set-key :focus-plaintext? true])
                   (-> ctx go_router/GoRouterHelper
                       (.pushNamed "edit"
                                   .pathParameters {"id" (:id note)}
                                   .extra {:autofocus true})))
                 nil))))

(defn get-started [saved-notes not-pinned hide-vid-tutorial? *svt? scaffold-messenger verified? ctx prefs tthm]
  (cond
    (nil? saved-notes)
    (m/SliverToBoxAdapter
     .child (f/widget
             :padding {:bottom 12
                       :top 24}
             :get {{tthm .-textTheme} m/Theme}
             m/Center
             (m/SizedBox
              .height 50
              .width 50
              .child (m/Center
                      .child (m/CircularProgressIndicator)))))

    (and  (tutorial/user-younger-than? 3)
          (<= (count saved-notes) 4)
          (not hide-vid-tutorial?))

    (m/SliverFillRemaining
     .hasScrollBody false
     .child
     (f/widget
      :let [button-size 180]
      :watch [brightness (rd/subscribe [::model/get-brightness])]
      :get {{tthm .-textTheme} m/Theme}
      :padding {:horizontal 8
                :vertical 4}
      :managed [overlaycontroller (m/OverlayPortalController) :dispose nil]
      :let [button (m/SizedBox
                    .width button-size
                    .child (m/ElevatedButton.icon
                            .iconAlignment m/IconAlignment.end
                            .onPressed (fn []
                                         (.toggle overlaycontroller))

                            .icon (m/Icon m/Icons.copy_all)
                            .label (m/OverlayPortal
                                    .controller overlaycontroller
                                    .overlayChildBuilder
                                    (fn [_]

                                      (m/Positioned
                                       .bottom 200
                                       .child
                                       (m/TapRegion
                                        .consumeOutsideTaps true
                                        .onTapOutside (fn [_]
                                                        (.hide overlaycontroller))
                                        .child (m/Card
                                                .elevation 4.0
                                                .child
                                                (model/outline
                                                 (f/widget
                                                  :padding {:vertical 12
                                                            :horizontal 12}
                                                  :get [m/MediaQuery]
                                                  (m/SizedBox
                                                   .width (- (.-width (.-size media-query))
                                                             100))

                                                  m/Column
                                                  .children
                                                  [(m/Align
                                                    .alignment m/Alignment.bottomLeft
                                                    .child (m/Text "Every note is a template!"
                                                                   .style (.-titleMedium tthm)))
                                                   (m/SizedBox .height 8)
                                                   (m/Align
                                                    .alignment m/Alignment.bottomLeft
                                                    .child (m/Text "Reuse sections and tags from old notes by cloning them. Give it a try!"))
                                                   (m/Row
                                                    .children [(m/Text "Clone icon: ")
                                                               (m/Icon m/Icons.copy_all)])])
                                                 0.1 2 20)))))
                                    .child
                                    (m/Text "Reuse content"))))]
      (m/Column
       .mainAxisSize m/MainAxisSize.min
       .crossAxisAlignment m/CrossAxisAlignment.start
       .mainAxisAlignment m/MainAxisAlignment.end
       .children
       [(model/outline button)
        (m/SizedBox
         .width button-size
         .child (tutorial/example-notes-popup false))

        (m/SizedBox
         .width button-size
         .child
         (m/ElevatedButton.icon
          .label (m/Text "Hide intro")
          .icon (m/Icon m/Icons.clear)
          .onPressed (fn []
                       (rd/dispatch [::model/update-user-options
                                     {"video_tutorial" true}])
                       (rd/dispatch [::model/fetch-user-options])
                       (reset! *svt? true)
                       (model/snackbar scaffold-messenger
                                       "Can be found again in settings!"))))])))

    (and
     (not (model/user-is-anonymous))
     (not verified?))
    (m/SliverFillRemaining
     .child
     (m/Align
      .alignment m/Alignment.bottomCenter
      .child (f/widget
              :padding {:top 10
                        :bottom 20}
              (m/ElevatedButton
               .onPressed
               (fn []
                 (-> ctx go_router/GoRouterHelper
                     (.pushNamed
                      "verify-email"))
                 nil)
               .child (m/Text "Verify email!")))))

    :else (m/SliverVisibility
           .visible false
           .sliver (m/SliverFillRemaining
                    .child (m/Text "how did this happen")))))

(defn archive? [view-archive]
  (m/SliverVisibility
   .visible (boolean view-archive)
   .sliver
   (m/SliverToBoxAdapter
    .child (m/Column
            .children
            [(f/widget
              :get {{tthm .-textTheme} m/Theme}

              :padding {:horizontal 10}
              (m/Text "Archive"
                      .style (.-titleLarge tthm)))
             (f/widget
              :padding {:horizontal 15}
              (m/Text "Long press to delete notes.
Swipe to restore from archive.
Leave using the properties menu top right"))
             (m/SizedBox .height 10)]))))

(defn reorder-pinned-tags [ctx tags]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    :watch [user-stream (when-let [uid  (model/uid)]
                          (.snapshots
                           (.doc
                            (.collection FirebaseFirestore.instance "users")
                            uid)))]

    :let [pinned-tags
          (if-let [parsed (model/firestore-stream->map user-stream)]
            (or (parsed "pinned-tags") [])
            [])]

    :watch [ptags (atom pinned-tags) :as *ptags]

    (m/AlertDialog
     .content
     (m/Container
      .height 200
      .width 300
      .child
      (m/ReorderableListView
       .shrinkWrap true
       .onReorder (fn [old-index new-index]
                    (let [x (model/vec-move pinned-tags old-index
                                            (if (< old-index new-index)
                                              (dec new-index)
                                              new-index))
                          db FirebaseFirestore.instance
                          ref (.doc
                               (.collection db "users")
                               (model/uid))]
                      (reset! *ptags x)
                      (await (.set ref {"pinned-tags" x}))))

       .children (map-indexed
                  (fn [i tag]
                    (f/widget
                     :key (str tag)
                     (m/ReorderableDragStartListener
                      .index i
                      .child
                      (m/ListTile
                       .title (m/Text tag)
                       .trailing (m/Icon m/Icons.drag_indicator)))))
                  ptags)))

     .actions [(m/TextButton
                .onPressed #(.pop navigator)
                .child (m/Text "Cancel"))
               (m/TextButton
                .onPressed #(.pop navigator)
                .child (m/Text "Ok"))]))))

(defn pin-tag [ctx tag]
  (m/showDialog
   .context ctx
   .builder
   (f/build
    :get [m/Navigator]
    :get {{tthm .-textTheme} m/Theme}
    :watch [all-notes (rd/subscribe [::model/get-notes])]
    :watch [user-stream (when-let [uid  (model/uid)]
                          (.snapshots
                           (.doc
                            (.collection FirebaseFirestore.instance "users")
                            uid)))]

    :let [pinned-tags (into #{}
                            (if-let [parsed (model/firestore-stream->map user-stream)]
                              (or (parsed "pinned-tags") [])
                              []))]

    (m/AlertDialog
     .content
     (m/Column
      .mainAxisSize m/MainAxisSize.min
      .children
      [(if (pinned-tags tag)
         (m/TextButton
          .onPressed (fn []
                       (let [db FirebaseFirestore.instance
                             ref (.doc
                                  (.collection db "users")
                                  (model/uid))]

                         (await (.set ref {"pinned-tags"
                                           (FieldValue.arrayRemove [tag])}
                                      (SetOptions .merge true)))
                         (.pop navigator)))
          .child (m/Text "Unpin tag"))

         (m/TextButton
          .onPressed (fn []
                       (let [db FirebaseFirestore.instance
                             ref (.doc
                                  (.collection db "users")
                                  (model/uid))]

                         (await (.set ref {"pinned-tags"
                                           (FieldValue.arrayUnion [tag])}
                                      (SetOptions .merge true)))
                         (.pop navigator)))
          .child (m/Text "Pin tag")))

       (m/TextButton
        .onPressed (when (> (count pinned-tags) 1)
                     (fn []
                       (.pop navigator)
                       (reorder-pinned-tags ctx pinned-tags)))
        .child (m/Text (if (> (count pinned-tags) 1)
                         "Reorder pinned tags"
                         "Reorder pinned tags (not enough tags)")))

       (m/TextButton
        .child (m/Text "Remove this tag from all notes")
        .onPressed (fn []
                     (popup/confirm
                      ctx
                      "Delete this tag from ALL notes? This can not be undone."
                      (fn []
                        (let [new-notes (mapv (fn [note]
                                                (update note :tags
                                                        (fn [tags]
                                                          (into []
                                                                (filter #(not= tag %))
                                                                tags))))
                                              all-notes)]

                          (rd/dispatch [::model/save-notes-event-fx new-notes])
                          (rd/dispatch [::model/refresh-notes]))
                        (.pop navigator)))))])

     .actions [(m/TextButton
                .onPressed #(.pop navigator)
                .child (m/Text "Done"))]))))

(def tutorial-text-note-count 3)
(def min-left 300)

(defn expanded-searchbar [*notes saved-notes *expanded-searchbar id->saved-notes-index selected-tags *selected-tags search-focus saved-notes-strings]
  (f/widget
   :watch [filter-by-section (rd/subscribe [::model/filter-by-section])]
   :padding {:bottom 12}
   :get [m/ScaffoldMessenger :search-tc]
   m/Card
   (m/Column
    .crossAxisAlignment m/CrossAxisAlignment.start
    .children
    [(m/IconButton
      .icon (m/Icon m/Icons.arrow_left)
      .onPressed
      (fn []
        (.-text! search-tc "")
        (reset! *notes saved-notes)
        (swap! *expanded-searchbar not)))

     (f/widget
      :padding {:horizontal 24}
      (m/Align
       .alignment m/Alignment.centerLeft)
      (m/ConstrainedBox
       .constraints (m/BoxConstraints
                     .maxWidth 300))
      (m/TextField
       .focusNode search-focus
       .autofocus true
       .decoration (m/InputDecoration
                    .labelText "Search all text")

       .controller search-tc
       .onChanged (fn [text]
                    (reset! *notes
                            (filter-notes text
                                          saved-notes
                                          id->saved-notes-index
                                          selected-tags
                                          filter-by-section
                                          scaffold-messenger
                                          saved-notes-strings))
                    nil)))

     (f/widget
      :watch [{:keys [all-tags]} (rd/subscribe [::model/all-tags-sub])]
      :padding {:left 24
                :vertical 12}
      :managed [tag-tc (m/TextEditingController)
                focus-node (m/FocusNode)]
      (m/Autocomplete
       .textEditingController tag-tc
       .focusNode focus-node
       .onSelected (fn [tag]
                     (swap! *selected-tags #(conj % tag))
                     (.-text! tag-tc "")
                     (model/unfocus-then-run
                      nil)
                     nil)

       .fieldViewBuilder
       (fn [_ tag-tc focus-node on-submitted]
         (f/widget
          :padding {:bottom 12}
          (m/Align
           .alignment m/Alignment.centerLeft)
          (m/ConstrainedBox
           .constraints (m/BoxConstraints
                         .maxWidth 300))
          (m/TextField
           .onTapOutside (fn [_]

                           (model/unfocus-then-run
                            nil))
           .decoration (m/InputDecoration
                        .labelText "Search for tag")
           .controller tag-tc
           .focusNode focus-node
           .onSubmitted (fn [tag]
                          (on-submitted)))))

       .optionsViewBuilder (fn [ctx on-selected options]
                             (f/widget
                              :watch [height-factor (atom 0.0) :as *height-factor
                                      visible? (atom true) :as *visible?]
                              :managed [_ (m/WidgetsBinding.instance.endOfFrame.then
                                           (fn [_]
                                             (reset! *height-factor 1.0))) :dispose nil]

                              :animate [height-factor height-factor
                                        :duration (Duration .milliseconds 150)
                                        :curve m/Curves.ease]
                              (m/ConstrainedBox
                               .constraints (m/BoxConstraints .maxWidth 300
                                                              .maxHeight 300))
                              (m/TapRegion
                               .onTapOutside (fn [_]
                                               (reset! *visible? false)))
                              (m/Visibility
                               .visible visible?)
                              m/Card
                              (m/ListView.builder
                               .shrinkWrap true
                               .itemCount (count options)
                               .itemBuilder (fn [_ i]
                                              (m/TextButton
                                               .child
                                               (m/Align
                                                .alignment m/Alignment.centerLeft
                                                .heightFactor height-factor
                                                .child
                                                (m/Text (nth options i)
                                                        .maxLines 1
                                                        .overflow m/TextOverflow.ellipsis))

                                               .onPressed (fn []
                                                            ;;This inserts into the textbox
                                                            (on-selected (nth options i))))))))
       .optionsBuilder
       (fn [^m/TextEditingValue {:flds [text]}]
         (let [^#/(Iterable String) result
               (into []
                     (filter (fn [^String x]
                               (string/includes? x text))
                             all-tags))]
           result))))])))

(defn ondismiss [view-archive
                 m
                 scaffold-messenger]
  (if view-archive
    (rd/dispatch
     [::model/save-note
      {:note (dissoc m :archived)}])

    (rd/dispatch
     [::model/save-note
      {:note (assoc m :archived true)}]))

  (rd/dispatch
   [::model/refresh-notes])

  (.showSnackBar
   scaffold-messenger
   (m/SnackBar
    .content (m/Text (if view-archive
                       "Item removed from archive. Undo?"
                       "Item archived. See three dots top right."))
    .action
    (m/SnackBarAction
     .label "Undo"
     .onPressed
     (fn []
       (rd/dispatch [::model/save-note {:note m}])
       (rd/dispatch [::model/refresh-notes]))))))

(defn filterchip [tag selected-tags *selected-tags tthm]
  (f/widget
   :padding {:right 4
             :bottom 4}
   :context ctx
   (m/InkWell
    .customBorder (m/RoundedRectangleBorder
                   .borderRadius theme/border-radius)

    .onLongPress
    (fn []
      (pin-tag ctx tag)))
   (m/FilterChip.elevated
    .elevation 0
    .selected (contains? selected-tags tag)
    ;; .shape (m/RoundedRectangleBorder
    ;;         .borderRadius (m/BorderRadius.circular 15))
    ;; .side (m/BorderSide
    ;;        .style (m/BorderStyle.none))

    .label  (m/Text (str tag))
    .onSelected (fn [selected?]
                  (if selected?
                    (swap! *selected-tags #(conj % tag))
                    (swap! *selected-tags #(disj % tag)))))))

(defn section-filtering-menu []
  (f/widget
   :context ctx
   :get {{tthm .-textTheme} m/Theme}
   :get {{cs .-colorScheme} m/Theme}
   :get {{hcolor .-highlightColor} m/Theme}

   :watch [filter-by-section (rd/subscribe [::model/filter-by-section])]
   (m/AnimatedCrossFade
    .crossFadeState (if filter-by-section
                      m/CrossFadeState.showFirst
                      m/CrossFadeState.showSecond)

    .duration (Duration .milliseconds 300)

    .firstChild  (m/IconButton
                  .icon (m/Icon m/Icons.table_rows_outlined
                                .size 48
                                .color hcolor)
                  .onPressed (fn []
                               (rd/dispatch [::model/set-key :filter-by-section
                                             nil])))
    .secondChild (m/PopupMenuButton
                  .icon (m/Icon m/Icons.filter_list
                                .color (.-onSurfaceVariant cs))
                  .key (m/ValueKey "small")
                  .tooltip "Filter by section type"
                  .itemBuilder (fn [_]
                                 #dart ^m/PopupMenuEntry
                                  [(m/PopupMenuItem
                                    .enabled false
                                    .value "_"
                                    .child (m/Text "Filter by section"
                                                   .style (.-bodyMedium tthm)))

                                   (m/PopupMenuItem
                                    .value "list"
                                    .child (m/Text "List"))

                                   (m/PopupMenuItem
                                    .value "voice"
                                    .child (m/Text "Voice"))

                                   (m/PopupMenuItem
                                    .value "table2"
                                    .child (m/Text "Table"))

                                   (m/PopupMenuItem
                                    .value "reminder"
                                    .child (m/Text "Reminder"))

                                   (m/PopupMenuItem
                                    .value "timer"
                                    .child (m/Text "Timer"))

                                   (m/PopupMenuItem
                                    .value "alarm"
                                    .child (m/Text "Alarm"))

                                   (m/PopupMenuItem
                                    .value "location"
                                    .child (m/Text "Location"))

                                   (m/PopupMenuItem
                                    .value "media2"
                                    .child (m/Text "Media"))])
                  .onSelected (fn [selection]
                                (rd/dispatch [::model/set-key :filter-by-section (if (= selection "all")
                                                                                   nil
                                                                                   selection)])

                                nil)))))

