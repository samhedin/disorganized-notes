(defn load-stored-notification-note? [ctx]
  (let [prefs (await (sp/SharedPreferences.getInstance))
        id? (.getString prefs "pending_notification_id")]
    (.remove prefs "pending_notification_id")
    (when id?
      (-> ctx go_router/GoRouterHelper
          (.pushNamed "edit"
                      .pathParameters {"id" id?}
                      .extra {:autofocus false})))
    nil))

(defn load-notification-message [ctx message ^m/ScaffoldMessengerState scaffold-messenger]

  (let
   [m (model/dart->clj-ds (.-data message))
    desc (m "description")
    id (m "note_id")]

    (.showSnackBar scaffold-messenger
                   (m/SnackBar
                    .content (m/Text (if desc
                                       (str "Reminder: " desc)
                                       "Reminder"))
                    .action (m/SnackBarAction
                             .label "Open"
                             .onPressed
                             (fn []
                               (dutils/popUntilRoot ctx)
                               (-> ctx go_router/GoRouterHelper
                                   (.pushNamed "edit"
                                               .pathParameters {"id" id}
                                               .extra {:autofocus false}))

                               nil))))))

(def ^m/Widget home-screen
  (f/build [^GoRouterState router-state]
           :watch [batch-delete-notes (rd/subscribe [::model/batch-delete-notes])]
           :get [m/ScaffoldMessenger m/Theme]
           :get {{cs .-colorScheme} m/Theme}

           :context ctx
           :bg-watcher ([{uid .-uid
                          email .-email} (.authStateChanges FirebaseAuth.instance)]
                        (println "SIGNUPDEBUGGING main " uid)
                        (if uid
                          (do
                            (rd/dispatch [::model/refresh-notes])
                            (rd/dispatch [::model/fetch-user-options])
                            
                            (model/log-analytics "login")
                            (await (utils/init-revenuecat- uid))

                            (when (not kIsWeb)
                              (await (handle-initial-notification-click))
                              (when Platform.isAndroid
                                (HomeWidget.registerInteractivityCallback widget-callback))
                              (await (messaging/initialize))
                              (rd/dispatch [::model/load-home-screen-widget-data])
                              (await (.init alarm/Alarm))))

                          (if kIsWeb
                              (-> ctx go_router/GoRouterHelper
                                  (.go
                                   "/login"))
                            (do
                             (utils/log-analytics "onboarding_starting")
                             (-> ctx
                                 go_router/GoRouterHelper
                                 (.go
                                  "/build-first-note")))))

                        (when (and uid email)
                          (let [db (fdb/FirestoreDB)]
                            (await (.setEmail
                                    db
                                    email
                                    uid)))))

           :managed [_ (f_widgets/AppLifecycleListener

                        .onHide (fn []
                                  ;;This makes sure we run all save callbacks when the user hides the screen.
                                  (rd/dispatch [::model/reset-restructure-mode])
                                  (.unfocus (.-primaryFocus (.instance m/FocusManager)))
                                  (rd/dispatch [::model/set-key :filter-by-section nil])
                                  nil)

                        .onResume (fn []
                                    (when (not kIsWeb)
                                      (.resetBadgeCountButKeepNotificationsInCenter Eraser))
                                    (load-stored-notification-note? ctx)))]
           (f/widget
            (m/Scaffold
             .floatingActionButtonLocation m/FloatingActionButtonLocation.endFloat
             .floatingActionButton
             (if
              (seq batch-delete-notes)
               (long-press-fab)
               (add-note-fab)))
            .body
            (m/SafeArea
             .child
             (read/list-notes)))))

(defonce router
  (GoRouter
   .initialLocation "/"
   .routes [(GoRoute
             .name "root"
             .path "/"
             .builder home-screen)

            (GoRoute
             .name "mindmap"
             .path "/mindmap"
             .builder mindmap)

            (GoRoute
             .name "build-first-note"
             .path "/build-first-note"
             .builder build-first-note)

            (go_router/GoRoute
             .name "edit"
             .path "/edit/:id"
             .pageBuilder (fn [ctx state]
                            (if kIsWeb
                              (go_router/NoTransitionPage
                               .child (edit/edit (-> state .-pathParameters (get "id"))
                                                 (.-extra state)))

                              (go_router/CustomTransitionPage
                               .key (.-pageKey state)
                               .child (edit/edit (-> state .-pathParameters (get "id"))
                                                 (.-extra state))
                               .transitionsBuilder (fn [ctx animation sec-animation child]
                                                     (m/FadeTransition
                                                      .opacity animation
                                                      .child child))))))

            

            (GoRoute
             .name "reminders"
             .path "/reminders"
             .builder reminders/show)

            (GoRoute
             .name "settings"
             .path "/settings"
             .builder settings/show)

            

            (GoRoute
             .name "manual"
             .path "/manual"
             .builder misc/manual)

            (GoRoute
             .name "image-painter"
             .path "/image-painter"
             .builder image-painter)

            (GoRoute
             .name "image-carousel"
             .path "/image-carousel"
             .pageBuilder (fn [ctx ^GoRouterState state]
                            (when (not kIsWeb)
                              (FirebaseCrashlytics.instance.setCustomKey
                               "opening-page" "image-carousel"))
                            (go_router/CustomTransitionPage
                             .key (.-pageKey state)
                             .child (carousel (-> state .-extra :images)
                                              (-> state .-extra :note)
                                              (-> state .-extra :folder-id)
                                              (-> state .-extra :misc))
                             .transitionDuration (Duration .milliseconds 200)
                             .transitionsBuilder (fn [ctx
                                                      ^m/Animation animation
                                                      ^m/Animation sec-animation
                                                      ^m/Widget child]
                                                   (let [t (#/(m/Tween m/Offset)
                                                            .begin (m/Offset 0.0 1.0)
                                                            .end (m/Offset 0.0 0.0))
                                                         tween (.chain t (m/CurveTween
                                                                          .curve (m/Curves.ease)))]
                                                     (m/SlideTransition
                                                      .position (.drive animation tween)
                                                      .child child))))))
            (GoRoute
             .name "image-carousel2"
             .path "/image-carousel2"
             .pageBuilder (fn [ctx ^GoRouterState state]
                            (when (not kIsWeb)
                              (FirebaseCrashlytics.instance.setCustomKey
                               "opening-page" "image-carousel2"))
                            (go_router/CustomTransitionPage
                             .key (.-pageKey state)
                             .child (carousel2 (-> state .-extra :image-urls)
                                               (-> state .-extra :note)
                                               (-> state .-extra :misc))
                             .transitionDuration (Duration .milliseconds 200)
                             .transitionsBuilder (fn [ctx
                                                      ^m/Animation animation
                                                      ^m/Animation sec-animation
                                                      ^m/Widget child]
                                                   (let [t (#/(m/Tween m/Offset)
                                                            .begin (m/Offset 0.0 1.0)
                                                            .end (m/Offset 0.0 0.0))
                                                         tween (.chain t (m/CurveTween
                                                                          .curve (m/Curves.ease)))]
                                                     (m/SlideTransition
                                                      .position (.drive animation tween)
                                                      .child child))))))

            (GoRoute
             .name "verify-email"
             .path "/verify-email"
             .builder verify-email)

            (GoRoute
             .name "login"
             .path "/login"
             .builder login)]))

       ;;https://api.flutter.dev/flutter/flutter_localizations/GlobalMaterialLocalizations-class.html
(def locales
  (mapv #(Locale %) ["en"] ;["en" "sv" "fr" "de" "es" "vi" "ro"]
        ))

(defn parse-disorganized-uri [uri]
  (println "parsing uri " (str uri))
  (let [uri (str uri)
        [_ query] (clojure.string/split uri #"\?" 2)
        _ (println "query " query)
        pairs (clojure.string/split query #"&")
        _ (println "pairs " pairs)
        result (->> pairs
                    (map #(clojure.string/split % #"=" 2))
                    (into {})
                    (select-keys ["noteId" "sectionId" "itemId"]))]
    (println "result " result)
    result))

^{:annotations [^:unique (pragma "vm:entry-point")]}
(defn widget-callback [uri]

  (await (firebase/Firebase.initializeApp
          .options (options/DefaultFirebaseOptions.currentPlatform)))
  (println "hello " uri)
  (rd/register-defaults!)
  (model/register!)

  (let [m (into {} (.splitQueryString Uri (str uri)))
        fdb (fdb/FirestoreDB)
        ;;m contains noteId, sectionId and itemId
        m (assoc m ;;lmao
                 "noteId"
                 (m "disorganized://checkboxtoggled?noteId"))
        note  (await (.getNoteById fdb (m "noteId")))
        note (into {} (for [[k v] note]
                        [(keyword k) (model/dart->clj-ds v)]))

        updated-note (update note
                             :sections
                             (fn [sections]

                               (into {}
                                     (map (fn [[name section]]
                                            (if (not= (section "id")
                                                      (m "sectionId"))
                                              [name section]
                                              [name (-> section
                                                        (update
                                                         "checked-content"
                                                         #(conj %
                                                                (reduce
                                                                 (fn [_ item]
                                                                   (when (= (item "id")
                                                                            (m "itemId"))
                                                                     (reduced (assoc item "checkbox" true))))
                                                                 nil
                                                                 (section "content"))))

                                                        (update "content"
                                                                #(into
                                                                  []
                                                                  (keep
                                                                   (fn [item]
                                                                     (when (not= (item "id")
                                                                                 (m "itemId"))
                                                                       item))
                                                                   %))))]))
                                          sections))))
        section (reduce (fn [_ [_ section]]
                          (when (= (section "id") (m "sectionId"))
                            (reduced section)))
                        nil
                        (updated-note :sections))]

    (rd/dispatch [::model/upload-note [updated-note true]])

    (await (HomeWidget.saveWidgetData "todo_list" (c/jsonEncode section)))
    (await (HomeWidget.updateWidget
            .androidName "NoteWidgetReceiver"))))

(defn handle-initial-notification-click []
  (when-let
   [notification (await
                  (.getInitialNotificationAction
                   (notif/AwesomeNotifications)))]
    (let [payload (model/dart->clj-ds (.-payload notification))
          action (.-buttonKeyPressed notification)
          id (payload "note_id")
          m {"note-id" (payload "note_id")
             "section-id" (payload "section_id")
             "description" (payload "description")}]
      (if (not (string/blank? action))
        (await (messaging/exec-reminder-action action m))

        (.pushNamed router "edit"
                    .pathParameters {"id" id}
                    .extra {:autofocus false})))))

(defn refresh-remote-config []
  (let [rc frc/FirebaseRemoteConfig.instance
        activated? (try (await (.fetchAndActivate rc))
                        (catch Exception e
                          (println "Couldn't fetch and activate rc")
                          nil))]))

(defn main
  []
  (f_widgets/WidgetsFlutterBinding.ensureInitialized)
  (await (firebase/Firebase.initializeApp
          .options (options/DefaultFirebaseOptions.currentPlatform)))
(when (not kDebugMode)
   (init-analytics))
  (init-remote-config)
  (init-appcheck)

  (add-brightness-observer)
  (rd/register-defaults!)
  (model/register!)
  (.enable FlutterCryptography)
  (when (and (not kDebugMode) (not kIsWeb))
    (set! (.-onError FlutterError)
          (.-recordFlutterFatalError FirebaseCrashlytics.instance)))

  (f/run
   :get [m/MediaQuery m/Theme]
   :context ctx
   :watch [{uid .-uid} (.authStateChanges FirebaseAuth.instance)]

   :bg-watcher ([alarm-set (alarm/Alarm.ringing)]
                (let [alarms (.-alarms alarm-set)]

                  (when (> (.-length alarms) 0)
                    (let [{note-id :note-id
                           section-id :section-id
                           section-position :section-position
                           section-name :section-name}
                          (reader/read-string (.-payload (.-first alarms)))]

                      (.pushNamed router "edit"
                                  .pathParameters {"id" note-id}
                                  .extra {:jumpto section-position
                                          :autofocus false})))))

   :bg-watcher ([cid (rd/subscribe [::model/current-note-id])]
                (when cid
                  (.pushNamed router "edit"
                              .pathParameters {"id" cid}
                              .extra {:autofocus false})))

   :bg-watcher ([prefs (rd/subscribe [::model/get-user-options])]
                (let [brightness
                      (cond
                        (= "dark" (prefs "color-scheme")) m/Brightness.dark
                        (= "light" (prefs "color-scheme")) m/Brightness.light
                        :else (m/WidgetsBinding.instance.platformDispatcher.-platformBrightness))]
                  (rd/dispatch [::model/set-brightness brightness])))

   :bg-watcher ([user-stream (when uid (.snapshots
                                        (.doc
                                         (.collection FirebaseFirestore.instance "users")
                                         uid))) :refresh-on uid]

                (when uid
                  (when-let [parsed (model/firestore-stream->map user-stream)]
                    (rd/dispatch [::model/set-key :prefs
                                  (or (parsed "preferences") {})]))))

   :get {{hours? .-alwaysUse24HourFormat} m/MediaQuery}
   :get {{tthm .-textTheme} m/Theme}

   :watch [prefs (rd/subscribe [::model/prefs])]

   :context ctx
   :managed [_ (m/WidgetsBinding.instance.endOfFrame.then
                (fn [_]
                  (load-stored-notification-note? ctx)

                  nil)) :dispose nil]

   :bind {:timeformat-24-hours? (if (some? hours?) hours? true)}
   (m/MediaQuery
    .data (.copyWith
           media-query
           .textScaler
           (p/TextScaler.linear
            (if prefs
              (or (prefs "font-scaling") 1.0)
              1.0))))

   (m/MaterialApp.router
    .routerConfig router
    .supportedLocales locales
    .themeMode (case (when prefs (prefs "color-scheme"))
                 "dark" m/ThemeMode.dark
                 "light" m/ThemeMode.light
                 m/ThemeMode.system)
    .title (str "Disorganized")
    .debugShowCheckedModeBanner false
    .theme (dt/customized-theme "light" prefs)

    .darkTheme (dt/customized-theme "dark" prefs))))
