(defn init-appcheck []
  ;;Split test activating this one!!!

  (FirebaseAppCheck.instance.activate
   .webProvider (ReCaptchaV3Provider "6LenbVQrAAAAAJJU1A6p-emj5yY1Se6I3MQxuZOP")
   .appleProvider AppleProvider.appAttest
   .androidProvider (if kDebugMode
                      AndroidProvider.debug
                      AndroidProvider.playIntegrity)))

(defn init-analytics []
  (println "init-analytics")
  (.setConsent FirebaseAnalytics.instance
               .adStorageConsentGranted false
               .analyticsStorageConsentGranted true
               .adPersonalizationSignalsConsentGranted false
               .adUserDataConsentGranted false
               .functionalityStorageConsentGranted true
               .personalizationStorageConsentGranted false
               .securityStorageConsentGranted true))

(defn init-remote-config []
  (let [rc frc/FirebaseRemoteConfig.instance]
    (.then (.setConfigSettings rc
                               (frc/RemoteConfigSettings
                                .fetchTimeout (Duration .minutes 1)
                                .minimumFetchInterval
                                (Duration .hours 1)))
           (fn [_]
             (.then (.setDefaults
                     rc
                     {"use_appcheck" "false"})
                    (fn [_]
                      (println "activating rc")
                      (.fetchAndActivate rc)))))))

(defn add-brightness-observer []
  ;;This makes sure we're notified when the device switches between dark/light mode
  (.addObserver f_widgets/WidgetsBinding.instance
                (reify :extends f_widgets/WidgetsBindingObserver

                  (didChangePlatformBrightness
                    [_]
                    (rd/dispatch [::model/set-brightness (m/WidgetsBinding.instance.platformDispatcher.-platformBrightness)])
                    nil))))

(defn sharing-intent-images [values  scaffold-messenger]
  (println "received sharing intent " values)
  (let [section-map (model/default-section-map "media2" 0 "shared")
        id (section-map "id")
        note (update (utils/init-new-note)
                     :sections #(assoc % id section-map))
        files (mapv #(XFile %) values)]
    (println "sharing-intent-images " values files)
    (rd/dispatch [::model/upload-note [note true]])
    (rd/dispatch [::model/set-current-note-id (:id note)])
    (await (media2/upload id "images" files))))

(defn sharing-intent-other [values  scaffold-messenger]
  (println "received sharing intent " values)
  (let [section-map (model/default-section-map "media2" 0 "shared")
        id (section-map "id")
        note (update (utils/init-new-note)
                     :sections #(assoc % id section-map))
        files (mapv #(XFile %) values)]

    (rd/dispatch [::model/upload-note [note true]])
    (rd/dispatch [::model/set-current-note-id (:id note)])
    (await (media2/upload id "other" files))))

(defn sharing-intent-text [text]
  (println "shared text " text)
  (if (and (string/includes? text "disorganized")
           (string/includes? text "openNote"))
    (let [id (second (string/split text #"="))]

      (println "found note " id)
      (rd/dispatch [::model/set-current-note-id id]))

    (let [note (assoc (utils/init-new-note)
                      :plaintext (str text))]

      (rd/dispatch [::model/upload-note [note true]])
      (rd/dispatch [::model/set-current-note-id (:id note)]))))

(defn handle-shared [shared scaffold-messenger]
  (when (seq shared)
    (let [type (.-type (first shared))
          values (.map shared (fn [x]
                                (.-value x)))]
      (cond
        (= type SharedMediaType.URL) (mapv sharing-intent-text values)
        (= type SharedMediaType.TEXT) (mapv sharing-intent-text values)
        (= type SharedMediaType.IMAGE)
        (sharing-intent-images values scaffold-messenger)
        :else (sharing-intent-other values  scaffold-messenger)))))

(defn add-note-fab []
  (f/widget
   :watch [brightness (rd/subscribe [::model/get-brightness])
           prefs (rd/subscribe [::model/prefs])]

   :let [fab-color-light (dt/fab-color prefs "light")
         fab-color-dark (dt/fab-color prefs "dark")]

   :padding {:bottom 30}

   (m/Column
    .mainAxisAlignment m/MainAxisAlignment.end
    .children
    [(f/widget
      :watch [saved-notes (rd/subscribe [::model/get-notes])]
      :context ctx
      :get [m/ScaffoldMessenger]

      :bg-watcher ([shared (when (not kIsWeb) (sharing-intent/FlutterSharingIntent.instance.getInitialSharing))]
                   (await (handle-shared shared scaffold-messenger)))

      :bg-watcher ([values (when (not kIsWeb)
                             (sharing-intent/FlutterSharingIntent.instance.getMediaStream))]

                   (await (handle-shared values scaffold-messenger)))

      (m/Tooltip
       .message "Create note"
       .child (read/add-note-fab-button prefs "main")))

     (m/SizedBox .height 5)

     (f/widget
      :context ctx
      :get [m/ScaffoldMessenger]
      (f/widget
       (m/Tooltip
        .message "Quick voice capture")
       (m/FloatingActionButton
        .backgroundColor (if (= m/Brightness.dark brightness)
                           fab-color-dark
                           fab-color-light)
        .shape (m/CircleBorder)
        .child (m/Icon m/Icons.mic
                       .color read/fab-icon-color)
        .onPressed
        (fn []
          (let [note (utils/init-new-recording-note)]
            (rd/dispatch [::model/upload-note  [note true]])
            (utils/log-analytics "note_created")
            (rd/dispatch [::model/set-new-plaintext ""])
            (rd/dispatch [::model/set-key :override-title ""])
            (rd/dispatch [::model/set-key :start-recording?
                          ;;Start recording for section id
                          (-> note :sections first first)])
            (-> ctx go_router/GoRouterHelper
                (.pushNamed "edit"
                            .pathParameters {"id" (:id note)}
                            .extra {:autofocus false}))
            nil)))))])))

(defn long-press-fab []
  (f/widget
   :context ctx
   :padding {:horizontal 30
             :left 70
             :bottom 70}

   :watch [prefs (rd/subscribe [::model/prefs])]
   :watch [brightness (rd/subscribe [::model/get-brightness])]

   :let [fab-color-light (dt/fab-color prefs "light")
         fab-color-dark (dt/fab-color prefs "dark")]

   (m/Row
    .mainAxisAlignment m/MainAxisAlignment.spaceBetween
    .children
    [(m/FloatingActionButton
      .shape (m/CircleBorder)
      .backgroundColor (if (= m/Brightness.dark brightness)
                         fab-color-dark
                         fab-color-light)
      .child
      (m/Icon m/Icons.cancel)
      .onPressed (fn []
                   (popup/confirm
                    ctx "Cancel batch delete?"
                    (fn []
                      (rd/dispatch [::model/cancel-batch-delete])))

                   nil))

     (m/FloatingActionButton
      .backgroundColor (if (= m/Brightness.dark brightness)
                         fab-color-dark
                         fab-color-light)

      .shape (m/CircleBorder)
      .child
      (m/Icon m/Icons.delete)
      .onPressed (fn []
                   (popup/confirm
                    ctx "Really delete these notes?"
                    (fn []
                      (rd/dispatch [::model/batch-delete!])))
                   nil))])))

